<Page x:Class="PBL3.Page1"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:local="clr-namespace:PBL3"
      mc:Ignorable="d"
      d:DesignHeight="792.8" d:DesignWidth="1536"
      Title="Trang chủ" Background="White">

    <Page.Resources>
        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Height" Value="110"/>
            <Setter Property="Margin" Value="50,25,50,25"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BorderMain" 
                        Background="{TemplateBinding Background}" 
                        CornerRadius="10" 
                        BorderBrush="#EEE" 
                        BorderThickness="1">

                            <Border.Effect>
                                <DropShadowEffect BlurRadius="30" Direction="0" Opacity="0.3" ShadowDepth="4"/>
                            </Border.Effect>

                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Cursor" Value="Hand"/>

                                <Setter TargetName="BorderMain" Property="Background" Value="#F5F5F5"/>

                                <Setter TargetName="BorderMain" Property="BorderBrush" Value="#C62828"/>

                                <Setter TargetName="BorderMain" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="40" Direction="100" Opacity="0.5" ShadowDepth="4"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#C62828" Padding="0,10,0,10">
            <Viewbox Height="130" Stretch="Uniform">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Image Source="/Assets/Images/QuocHuy.png" Width="50" Height="70" Margin="0,0,10,0"/>
                    <TextBlock Text="BỘ GIAO THÔNG VẬN TẢI" Foreground="White" FontSize="25" FontFamily="Calibri" VerticalAlignment="Center"/>
                </StackPanel>
            </Viewbox>
        </Border>

        <Viewbox Grid.Row="1" Height="115" Margin="0,30,0,50">
            <StackPanel>
                <TextBlock Text="QUẢN LÝ VI PHẠM" FontSize="50" FontFamily="Calibri" HorizontalAlignment="Center" Foreground="#333"/>
                <TextBlock Text="GIAO THÔNG" FontSize="50" FontFamily="Calibri" HorizontalAlignment="Center" Foreground="#333"/>
            </StackPanel>
        </Viewbox>

        <Grid Grid.Row="2" VerticalAlignment="Top">
            <Viewbox StretchDirection="DownOnly" Stretch="Uniform">
                <UniformGrid Columns="2" HorizontalAlignment="Center" Width="1200" Margin="0,0,0,150">

                    <Button Style="{StaticResource ModernButtonStyle}" x:Name="btnTraCuuNhanh">
                        <Grid Width="480">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="30"/>
                            </Grid.ColumnDefinitions>
                            <Viewbox Grid.Column="0" Width="80" Height="80" Margin="0,0,20,0">
                                <Path Fill="#C62828" Data="M9.5,3A6.5,6.5 0 0,1 16,9.5C16,11.11 15.41,12.59 14.44,13.73L14.71,14H15.5L20.5,19L19,20.5L14,15.5V14.71L13.73,14.44C12.59,15.41 11.11,16 9.5,16A6.5,6.5 0 0,1 3,9.5A6.5,6.5 0 0,1 9.5,3M9.5,5C7,5 5,7 5,9.5C5,12 7,14 9.5,14C12,14 14,12 14,9.5C14,7 12,5 9.5,5Z" />
                            </Viewbox>
                            <TextBlock Grid.Column="1" Text="Tra cứu nhanh" VerticalAlignment="Center" FontSize="35" FontFamily="Calibri"/>
                            <TextBlock Grid.Column="2" Text=">" VerticalAlignment="Center" Foreground="Gray" FontSize="40"/>
                        </Grid>
                    </Button>

                    <Button Style="{StaticResource ModernButtonStyle}">
                        <Grid Width="480">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="30"/>
                            </Grid.ColumnDefinitions>
                            <Viewbox Grid.Column="0" Width="80" Height="80" Margin="0,0,20,0">
                                <Path Fill="#C62828" Data="M13,12H20V13.5H13M13,9.5H20V11H13M13,14.5H20V16H13M21,4H3A2,2 0 0,0 1,6V19A2,2 0 0,0 3,21H21A2,2 0 0,0 23,19V6A2,2 0 0,0 21,4M21,19H12V6H21" />
                            </Viewbox>
                            <TextBlock Grid.Column="1" Text="Tra cứu luật" VerticalAlignment="Center" FontSize="35" FontFamily="Calibri"/>
                            <TextBlock Grid.Column="2" Text=">" VerticalAlignment="Center" Foreground="Gray" FontSize="40"/>
                        </Grid>
                    </Button>

                    <Button Style="{StaticResource ModernButtonStyle}" x:Name="btnDangNhap" Click="BtnDangNhap_Click">
                        <Grid Width="480">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="30"/>
                            </Grid.ColumnDefinitions>
                            <Viewbox Grid.Column="0" Width="80" Height="80" Margin="0,0,20,0">
                                <Path Fill="#C62828" Data="M12,4A4,4 0 0,1 16,8A4,4 0 0,1 12,12A4,4 0 0,1 8,8A4,4 0 0,1 12,4M12,6A2,2 0 0,0 10,8A2,2 0 0,0 12,10A2,2 0 0,0 14,8A2,2 0 0,0 12,6M12,13C14.67,13 20,14.33 20,17V20H4V17C4,14.33 9.33,13 12,13M12,14.9C9.03,14.9 5.9,16.36 5.9,17V18.1H18.1V17C18.1,16.36 14.97,14.9 12,14.9Z" />
                            </Viewbox>
                            <TextBlock Grid.Column="1" Text="Đăng nhập" VerticalAlignment="Center" FontSize="35" FontFamily="Calibri"/>
                            <TextBlock Grid.Column="2" Text=">" VerticalAlignment="Center" Foreground="Gray" FontSize="40"/>
                        </Grid>
                    </Button>

                    <Button Style="{StaticResource ModernButtonStyle}">
                        <Grid Width="480">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="30"/>
                            </Grid.ColumnDefinitions>
                            <Viewbox Grid.Column="0" Width="80" Height="80" Margin="0,0,20,0">
                                <Path Fill="#C62828" Data="M20,2H4A2,2 0 0,0 2,4V22L6,18H20A2,2 0 0,0 22,16V4A2,2 0 0,0 20,2M6,9H18V11H6M14,14H6V12H14M18,8H6V6H18" />
                            </Viewbox>
                            <TextBlock Grid.Column="1" Text="Phản ánh" VerticalAlignment="Center" FontSize="35" FontFamily="Calibri"/>
                            <TextBlock Grid.Column="2" Text=">" VerticalAlignment="Center" Foreground="Gray" FontSize="40"/>
                        </Grid>
                    </Button>

                </UniformGrid>
            </Viewbox>
        </Grid>
    </Grid>
</Page>