                        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,10">
                            <TextBlock Text="Phân loại xe" FontSize="16" Foreground="#333" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <ToggleButton x:Name="tgPhanLoai" Width="40" Height="20" Background="#C62828" Cursor="Hand" Checked="tgPhanLoai_Checked" Unchecked="tgPhanLoai_Checked">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="borderOut" CornerRadius="10" BorderThickness="2" BorderBrush="#C62828" Background="White">
                                            <Ellipse x:Name="knob" Width="14" Height="14" Fill="#C62828" HorizontalAlignment="Left" Margin="2,0,0,0"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="knob" Property="HorizontalAlignment" Value="Right"/>
                                                <Setter TargetName="knob" Property="Margin" Value="0,0,2,0"/>
                                                <Setter TargetName="borderOut" Property="Background" Value="#FDECEE"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                        </StackPanel>

                        <!-- Chart Area -->
                        <Border Grid.Row="3" BorderBrush="#CCC" BorderThickness="1" Background="White" Margin="0,0,0,0">
                            <Grid Margin="10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock x:Name="txtChartTitle" Text="Biểu đồ thống kê lỗi vi phạm theo tháng" FontSize="18" Foreground="#333" HorizontalAlignment="Center" Margin="0,0,0,10"/>

                                <Grid Grid.Row="1" Margin="10,0,10,0">
                                    <!-- Y Axis GridLines -->
                                    <ItemsControl x:Name="icYAxisLines">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <UniformGrid Columns="1"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="#EEE" BorderThickness="0,0,0,1" VerticalAlignment="Bottom" Height="30" Margin="40,0,0,0"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!-- Y Axis Labels -->
                                    <ItemsControl x:Name="icYAxisLabels" VerticalAlignment="Stretch" Margin="0,0,0,0">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <UniformGrid Columns="1"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}" Foreground="#666" FontSize="12" VerticalAlignment="Bottom" Margin="0,0,0,-8" HorizontalAlignment="Left" Width="30" TextAlignment="Right"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!-- Bars -->
                                    <ItemsControl x:Name="icBars" Margin="45,0,0,0" VerticalAlignment="Bottom" Height="300">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <UniformGrid Rows="1"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <ItemsControl ItemsSource="{Binding Series}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <UniformGrid Rows="1"/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="2,0,2,0">
                                                                <Rectangle Width="15" Height="{Binding Height}" Fill="{Binding Color}" VerticalAlignment="Bottom"/>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>

                                <!-- X Axis Labels -->
                                <ItemsControl x:Name="icXAxisLabels" Grid.Row="2" Margin="45,5,0,0">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Rows="1"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" Foreground="#666" FontSize="12" HorizontalAlignment="Center"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- Legend -->
                                <ItemsControl x:Name="icLegend" Grid.Row="3" Margin="0,15,0,0" HorizontalAlignment="Center">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="10,0">
                                                <Rectangle Width="10" Height="10" Fill="{Binding Color}" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding Name}" Margin="5,0,0,0" FontSize="12" Foreground="#666" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>