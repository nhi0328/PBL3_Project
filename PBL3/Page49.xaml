            <Grid Grid.Row="1" Panel.ZIndex="1">
                <TextBlock Grid.Row="0" Text="THỐNG KÊ VI PHẠM" FontSize="35" FontFamily="Calibri" Foreground="#333" HorizontalAlignment="Center" Padding="0,35,0,20"/>
