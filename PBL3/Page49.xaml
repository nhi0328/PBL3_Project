                            <Border CornerRadius="8" BorderBrush="#CCC" BorderThickness="1" Background="White" Height="40">
                                <ComboBox x:Name="cboValue" Width="150" FontSize="18" VerticalContentAlignment="Center" Background="White" BorderThickness="0" SelectionChanged="cboValue_SelectionChanged">
                                </ComboBox>
                            </Border>
                        </StackPanel>

