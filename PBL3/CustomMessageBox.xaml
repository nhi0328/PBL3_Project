<Window x:Class="PBL3.CustomMessageBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Thông báo" Height="200" Width="400"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" Topmost="True">

    <Border Background="White" CornerRadius="10" BorderBrush="#C62828" BorderThickness="2" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Opacity="0.3" ShadowDepth="2"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="60"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#C62828" CornerRadius="8,8,0,0">
                <TextBlock x:Name="txtTitle" Text="Thông báo hệ thống" Foreground="White" FontSize="18" FontFamily="Calibri" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </Border>

            <TextBlock Grid.Row="1" x:Name="txtMessage" Text="Đây là nội dung thông báo!" FontSize="18" FontFamily="Calibri" Foreground="#333" TextWrapping="Wrap" TextAlignment="Center" VerticalAlignment="Center" Margin="20"/>

            <Button Grid.Row="2" Content="ĐỒNG Ý" Width="120" Height="35" Background="#C62828" Foreground="White" FontSize="16" FontFamily="Calibri" BorderThickness="0" Cursor="Hand" Click="btnOK_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>
            </Button>
        </Grid>
    </Border>
</Window>