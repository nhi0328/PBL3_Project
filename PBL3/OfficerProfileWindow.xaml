<Window x:Class="PBL3.OfficerProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Thông tin Cán bộ" Height="300" Width="500"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen">
    <Border Background="White" BorderBrush="#ccc" BorderThickness="1" CornerRadius="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Opacity="0.2" ShadowDepth="0"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Button Grid.Row="0" HorizontalAlignment="Right" VerticalAlignment="Top" 
        Content="&#10006;" FontSize="14" Width="20" Height="20" Margin="5" Cursor="Hand" 
        Click="btnClose_Click" Background="Transparent" BorderThickness="0">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Foreground" Value="#888"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="10">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,1"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#FDEAEA"/>
                                            <Setter Property="Foreground" Value="#C62828"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#F8C4C4"/>
                                            <Setter Property="Foreground" Value="#A02020"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>

            <TextBlock Grid.Row="0" Text="THÔNG TIN TÀI KHOẢN" FontSize="25" FontFamily="Calibri" 
                       HorizontalAlignment="Center" Margin="0,10,0,5" Foreground="#111" FontWeight="Bold"/>

            <Grid Grid.Row="1" Margin="20,0,20,20">

                <Grid Grid.Column="1" Margin="10,0,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="40"/>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Số hiệu:" FontSize="17" FontFamily="Calibri" VerticalAlignment="Center"/>
                    <Border Grid.Row="0" Grid.Column="2" BorderBrush="#333" BorderThickness="1" Padding="15,0" CornerRadius="5" Margin="0,5,0,5">
                        <TextBlock x:Name="txtOfficerId" Text="..." FontSize="15" FontFamily="Calibri" VerticalAlignment="Center" Foreground="#333"/>
                    </Border>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="CCCD:" FontSize="17" FontFamily="Calibri" VerticalAlignment="Center"/>
                    <Border Grid.Row="1" Grid.Column="1" BorderBrush="#333" BorderThickness="1" Padding="15,0" CornerRadius="5" Margin="0,5,0,5">
                        <TextBlock x:Name="txtCCCD" Text="..." FontSize="15" FontFamily="Calibri" VerticalAlignment="Center" Foreground="#333"/>
                    </Border>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Đổi mật khẩu" FontSize="17" FontFamily="Calibri" VerticalAlignment="Bottom"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Mật khẩu mới:" FontSize="17" FontFamily="Calibri" VerticalAlignment="Center"/>
                    <Border Grid.Row="3" Grid.Column="1" BorderBrush="#333" BorderThickness="1" Padding="10,0" CornerRadius="5" Margin="0,5,0,5">
                        <TextBox x:Name="txtPassword" Background="Transparent" BorderThickness="0" FontSize="15" FontFamily="Calibri" VerticalAlignment="Center" Foreground="#333"/>
                    </Border>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Nhập lại mật khẩu:" FontSize="17" FontFamily="Calibri" VerticalAlignment="Center"/>
                    <Border Grid.Row="4" Grid.Column="1" BorderBrush="#333" BorderThickness="1" Padding="10,0" CornerRadius="5" Margin="0,5,0,5">
                        <TextBox x:Name="txtConfirmPassword" Background="Transparent" BorderThickness="0" FontSize="15" FontFamily="Calibri" VerticalAlignment="Center" Foreground="#333"/>
                    </Border>
                </Grid>
            </Grid>

            <Grid Grid.Row="6" Margin="10,0,10,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" x:Name="btnCancel" Content="Hủy" Width="80" Height="25" Background="White" Foreground="#333" BorderBrush="#ccc" BorderThickness="1" Cursor="Hand" Click="btnCancel_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="5">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#F5F5F5"/>
                                                <Setter TargetName="border" Property="BorderBrush" Value="#bbb"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#EBEBEB"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Grid.Column="1" x:Name="btnSave" Content="Lưu" Width="80" Height="25" Background="#C62828" Foreground="White" BorderThickness="0" Cursor="Hand" Click="btnSave_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="5">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#A02020"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#800000"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>

        </Grid>
    </Border>
</Window>