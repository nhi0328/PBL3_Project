<Page x:Class="PBL3.Page10"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PBL3"
        mc:Ignorable="d"
        Title="Tra cứu nhanh" 
        d:DesignHeight="792.8" d:DesignWidth="1536"
        Background="White">
    <Page.Resources>

        <Style x:Key="RedContextMenuStyle" TargetType="ContextMenu">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#c72421"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="8">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="15" Opacity="0.2" ShadowDepth="3"/>
                            </Border.Effect>
                            <ItemsPresenter Margin="5"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RedMenuItemStyle" TargetType="MenuItem">
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Border" Background="Transparent" Padding="10,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="30"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <ContentPresenter Grid.Column="0" ContentSource="Icon" VerticalAlignment="Center"/>
                                <ContentPresenter Grid.Column="1" ContentSource="Header" VerticalAlignment="Center" Margin="10,0"/>
                            </Grid>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#c72421"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>
    <Grid>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="100"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#c72421">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" Opacity="0.7" ShadowDepth="3" Direction="0"/>
                </Border.Effect>
                <StackPanel Orientation="Horizontal" Margin="60,0,0,0" HorizontalAlignment="Left">
                    <Image Source="/Assets/Images/QuocHuy.png" Width="60" Height="60" Margin="0,0,20,0"/>
                    <TextBlock Text="BỘ GIAO THÔNG VẬN TẢI" Foreground="White" FontSize="32" FontFamily="Calibri" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <Grid Grid.Row="1" Panel.ZIndex="1">
                <Button Content="&lt; Quay lại" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="30" Background="Transparent" BorderThickness="0" FontSize="20" Cursor="Hand" Click="BtnBack_Click"/>
                <StackPanel>
                    <TextBlock Text="TRA CỨU NHANH" FontSize="35" FontFamily="Calibri" Foreground="#333" HorizontalAlignment="Center" Padding="0,35,0,20"/>

                    <Border Background="White" CornerRadius="20" Margin="250,0,250,10">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="40" Opacity="0.3" ShadowDepth="0" Direction="70"/>
                        </Border.Effect>

                        <StackPanel Margin="20">
                            <TextBlock Text="Nhập biển số xe cần tra cứu:" FontSize="20" Foreground="Black"/>
                            <Grid Height="50" Margin="0,20,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="150"/>
                                </Grid.ColumnDefinitions>

                                <Border CornerRadius="8" BorderBrush="#CCC" BorderThickness="1" Background="#FAFAFA">
                                    <TextBox Grid.Column="1" VerticalContentAlignment="Center" FontSize="20"
                                        Background="Transparent" BorderThickness="0" Foreground="#333" 
                                            x:Name="txtIdentifier">
                                        <TextBox.Resources>
                                            <Style TargetType="{x:Type TextBox}">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="{x:Type TextBox}">
                                                            <Grid Margin="10">
                                                                <ScrollViewer x:Name="PART_ContentHost"/>
                                                                <TextBlock Text="Ví dụ: 30A-123.45" x:Name="UserPlaceholder" 
                                                                    Foreground="Gray" VerticalAlignment="Center" 
                                                                    IsHitTestVisible="False"
                                                                    Visibility="Collapsed"/>
                                                            </Grid>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="Text" Value="">
                                                                    <Setter TargetName="UserPlaceholder" Property="Visibility" Value="Visible"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </TextBox.Resources>
                                    </TextBox>
                                </Border>

                                <Button Grid.Column="1" Margin="15,0,0,0" Background="#C62828" Cursor="Hand" Click="BtnSearch_Click">
                                    <StackPanel Orientation="Horizontal" Width="130" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Viewbox Width="25" Height="25" HorizontalAlignment="Left" Margin="10,0,0,0">
                                            <Path Fill="White" Data="M9.5,3A6.5,6.5 0 0,1 16,9.5C16,11.11 15.41,12.59 14.44,13.73L14.71,14H15.5L20.5,19L19,20.5L14,15.5V14.71L13.73,14.44C12.59,15.41 11.11,16 9.5,16A6.5,6.5 0 0,1 3,9.5A6.5,6.5 0 0,1 9.5,3M9.5,5C7,5 5,7 5,9.5C5,12 7,14 9.5,14C12,14 14,12 14,9.5C14,7 12,5 9.5,5Z" />
                                        </Viewbox>
                                        <TextBlock Text="Tra cứu" FontSize="25" FontFamily="Calibri" VerticalAlignment="Center" Margin="10,0,0,0" Foreground="White" />
                                    </StackPanel>

                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>

                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="border" Property="Background" Value="#B71C1C"/>
                                                            </Trigger>
                                                            <Trigger Property="IsPressed" Value="True">
                                                                <Setter TargetName="border" Property="Background" Value="#800000"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </Grid>

                            <DataGrid Margin="0,30,0,0" Height="250" AutoGenerateColumns="False" CanUserAddRows="False" 
                              HeadersVisibility="Column" Background="White" RowHeaderWidth="0" BorderBrush="#EEE" BorderThickness="1">
                                <DataGrid.ColumnHeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="#F5F5F5"/>
                                        <Setter Property="Foreground" Value="#333"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Padding" Value="10,15"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                                        <Setter Property="BorderBrush" Value="#DDD"/>
                                    </Style>
                                </DataGrid.ColumnHeaderStyle>
                                <DataGrid.CellStyle>
                                    <Style TargetType="DataGridCell">
                                        <Setter Property="Padding" Value="10"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="DataGridCell">
                                                    <Border Padding="{TemplateBinding Padding}" BorderBrush="Transparent" BorderThickness="0" Background="{TemplateBinding Background}">
                                                        <ContentPresenter VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Setter Property="TextBlock.TextAlignment" Value="Center"/>
                                    </Style>
                                </DataGrid.CellStyle>

                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="STT" Width="50" Binding="{Binding STT}"/>
                                    <DataGridTextColumn Header="Lỗi vi phạm" Width="*" Binding="{Binding Loi}"/>
                                    <DataGridTextColumn Header="Thời gian" Width="200" Binding="{Binding ThoiGian}"/>
                                    <DataGridTextColumn Header="Địa điểm" Width="*" Binding="{Binding DiaDiem}"/>
                                    <DataGridTextColumn Header="Trạng thái" Width="150" Binding="{Binding TrangThai}" FontWeight="Bold" Foreground="#c72421"/>
                                    <DataGridTemplateColumn Header="Chi tiết" Width="100">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="Xem >" Foreground="Blue" Cursor="Hand" TextDecorations="Underline" HorizontalAlignment="Center"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>

                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Page>