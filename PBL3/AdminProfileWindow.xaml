<Window x:Class="PBL3.AdminProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Thông tin tài khoản" Height="300" Width="500"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen">
    <Border Background="White" BorderBrush="#ccc" BorderThickness="1" CornerRadius="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Opacity="0.2" ShadowDepth="0"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
				<RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Close Button -->
            <Button Grid.Row="0" HorizontalAlignment="Right" VerticalAlignment="Top" 
                    Content="&#10006;" FontSize="14" Width="20" Height="20" Margin="5" Cursor="Hand" 
                    Click="btnClose_Click" Background="Transparent" BorderThickness="0">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Foreground" Value="#888"/> <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="10">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,1"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#FDEAEA"/>
                                            <Setter Property="Foreground" Value="#C62828"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#F8C4C4"/>
                                            <Setter Property="Foreground" Value="#A02020"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>

            <!-- Title -->
            <TextBlock Grid.Row="0" Text="THÔNG TIN TÀI KHOẢN" FontSize="25" FontFamily="Calibri" 
                       HorizontalAlignment="Center" Margin="0,10,0,0" Foreground="#111" FontWeight="Bold"/>

            <!-- Content -->
            <Grid Grid.Row="1" Margin="10,0,10,9">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Avatar -->
                <Border BorderBrush="Black" BorderThickness="1" Width="110" Height="160" HorizontalAlignment="Left" VerticalAlignment="Top">
                    <Grid>
                        <Image x:Name="imgAvatar" Stretch="UniformToFill"/>
                        <TextBlock x:Name="txtNoImage" Text="Không có ảnh" Foreground="Gray" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>
                    </Grid>
                </Border>

                <!-- Details -->
                <Grid Grid.Column="1" Margin="0,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="17"/>
                        <RowDefinition Height="40"/>
					    <RowDefinition Height="40"/>
                    </Grid.RowDefinitions>

                    <!-- Row 0 -->
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Tên tài khoản:" FontSize="15" FontFamily="Calibri" VerticalAlignment="Center"/>
                    <Border Grid.Row="0" Grid.Column="1" BorderBrush="Black" BorderThickness="1" Padding="15,0" Margin="0,5,0,5" CornerRadius="5">
                        <TextBlock x:Name="txtFullName" Text="..." FontSize="15" FontFamily="Calibri" VerticalAlignment="Center" Foreground="#333"/>
                    </Border>

                    <!-- Row 1 -->
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="ID tài khoản:" FontSize="15" FontFamily="Calibri" VerticalAlignment="Center"/>
                    <Border Grid.Row="1" Grid.Column="1" BorderBrush="Black" BorderThickness="1" Padding="15,0" Margin="0,5,0,5" CornerRadius="5">
                        <TextBlock x:Name="txtAdminId" Text="..." FontSize="15" FontFamily="Calibri" VerticalAlignment="Center" Foreground="#333"/>
                    </Border>

                    <!-- Row 2 -->
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Tên đăng nhập:" FontSize="15" FontFamily="Calibri" VerticalAlignment="Center"/>
                    <Border Grid.Row="2" Grid.Column="1" BorderBrush="Black" BorderThickness="1" Padding="15,0" Margin="0,5,0,5" CornerRadius="5">
                        <TextBlock x:Name="txtUsername" Text="..." FontSize="15" FontFamily="Calibri" VerticalAlignment="Center" Foreground="#333"/>
                    </Border>

                    <!-- Row 3 -->
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Đổi mật khẩu" FontSize="15" FontFamily="Calibri" VerticalAlignment="Bottom"/>
					<TextBlock Grid.Row="4" Grid.Column="0" Text="Mật khẩu mới:" FontSize="15" FontFamily="Calibri" VerticalAlignment="Center"/>
					<Border Grid.Row="4" Grid.Column="1" BorderBrush="Black" BorderThickness="1" Padding="10,0" Margin="0,5,0,5" CornerRadius="5">
                        <TextBox x:Name="txtPassword" Background="Transparent" BorderThickness="0" FontSize="15" FontFamily="Calibri" VerticalAlignment="Center" Foreground="#333"/>
                    </Border>

                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Nhập lại mật khẩu:" FontSize="15" FontFamily="Calibri" VerticalAlignment="Center"/>
                    <Border Grid.Row="5" Grid.Column="1" BorderBrush="Black" BorderThickness="1" Padding="10,0" Margin="0,5,0,5" CornerRadius="5">
                        <TextBox x:Name="txtConfirmPassword" Background="Transparent" BorderThickness="0" FontSize="15" FontFamily="Calibri" VerticalAlignment="Center" Foreground="#333"/>
                    </Border>
                </Grid>
			
            </Grid>

			<Grid Grid.Row="6" Margin="10,0,10,10">
				<Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
				<Button Grid.Column="0" x:Name="btnCancel" Content="Hủy" Width="80" Height="25" Background="White" Foreground="#333" BorderBrush="#ccc" BorderThickness="1" Cursor="Hand" Click="btnCancel_Click" Margin="0,0,0,0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="5">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#F5F5F5"/>
                                                <Setter TargetName="border" Property="BorderBrush" Value="#bbb"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#EBEBEB"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

				<Button Grid.Column="1" x:Name="btnSave" Content="Lưu" Width="80" Height="25" Background="#C62828" Foreground="White" BorderThickness="0" Cursor="Hand" Click="btnSave_Click"> 
					<Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="5">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#A02020"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#800000"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
				</Button>
			</Grid>
		
	
        </Grid>
    </Border>
</Window>