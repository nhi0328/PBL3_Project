<Page x:Class="PBL3.Page51"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PBL3"
        mc:Ignorable="d"
        Title="Tra cứu luật admin" 
        d:DesignHeight="792.8" d:DesignWidth="1536"
        FontFamily="Calibri"
        Background="White">
    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Width" Value="2"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid x:Name="Bg" Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="true">
                                <Track.Thumb>
                                    <Thumb x:Name="Thumb">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="{x:Type Thumb}">
                                                <Border Background="#CCCCCC" CornerRadius="4" Margin="2,0,2,0"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RightArrowExpanderStyle" TargetType="Expander">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <Border x:Name="Border" CornerRadius="8" Background="{TemplateBinding Background}" Margin="{TemplateBinding Margin}">
                            <DockPanel>
                                <ToggleButton x:Name="HeaderSite" DockPanel.Dock="Top" Cursor="Hand" 
                                          IsChecked="{Binding IsExpanded, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border x:Name="HeaderBorder" Background="Transparent" CornerRadius="8">
                                                <Grid Margin="10,10,0,10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Viewbox Grid.Column="0" Width="24" Height="24" Margin="0,0,10,0">
                                                        <Path Fill="#C62828" Data="M13,14H11V10H13M13,18H11V16H13M1,21H23L12,2L1,21Z" />
                                                    </Viewbox>
                                                    <ContentPresenter Grid.Column="1" ContentSource="Content" VerticalAlignment="Center" />
                                                    <TextBlock x:Name="Arrow" Grid.Column="2" Text="v" FontFamily="Century Gothic" FontWeight="Regular" Foreground="#333" FontSize="18" Margin="0,0,15,0" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                                                        <TextBlock.RenderTransform>
                                                            <RotateTransform Angle="0"/>
                                                        </TextBlock.RenderTransform>
                                                    </TextBlock>
                                                </Grid>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="HeaderBorder" Property="Background" Value="#F0F0F0"/>
                                                </Trigger>
                                                <DataTrigger Binding="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}" Value="True">
                                                    <Setter TargetName="Arrow" Property="RenderTransform">
                                                        <Setter.Value>
                                                            <RotateTransform Angle="180"/>
                                                        </Setter.Value>
                                                    </Setter>
                                                </DataTrigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                    <ToggleButton.Content>
                                        <TextBlock Text="{Binding DataContext.TenLoi, RelativeSource={RelativeSource TemplatedParent}}" FontSize="22" FontFamily="Calibri" Foreground="#333" TextWrapping="Wrap" />
                                    </ToggleButton.Content>
                                </ToggleButton>
                                <ContentPresenter x:Name="ExpandSite" Visibility="Collapsed" Content="{TemplateBinding Content}" Margin="{TemplateBinding Padding}"/>
                            </DockPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ExpandSite" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RedContextMenuStyle" TargetType="ContextMenu">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#c72421"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="8">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="15" Opacity="0.2" ShadowDepth="3"/>
                            </Border.Effect>
                            <ItemsPresenter Margin="5"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RedMenuItemStyle" TargetType="MenuItem">
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Border" Background="Transparent" Padding="10,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="30"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <ContentPresenter Grid.Column="0" ContentSource="Icon" VerticalAlignment="Center"/>
                                <ContentPresenter Grid.Column="1" ContentSource="Header" VerticalAlignment="Center" Margin="10,0"/>
                            </Grid>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#c72421"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="370"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#C62828" Margin="0,100,0,0">
            <Grid Margin="0,35,0,0" VerticalAlignment="Top" >
                <Grid.RowDefinitions>
                    <RowDefinition Height="80"/>
                    <RowDefinition Height="80"/>
                    <RowDefinition Height="80"/>
                    <RowDefinition Height="80"/>
                    <RowDefinition Height="80"/>
                    <RowDefinition Height="80"/>
                </Grid.RowDefinitions>
                <Button Click="btnTraCuuNhanh_Click" Background="#C62828" Grid.Row="0" BorderThickness="0" VerticalAlignment="Top" Height="80">
                    <StackPanel Orientation="Horizontal" Width="350">
                        <Viewbox Width="50" Height="50" HorizontalAlignment="Left" Margin="10,0,0,0">
                            <Path Fill="White" Data="M9.5,3A6.5,6.5 0 0,1 16,9.5C16,11.11 15.41,12.59 14.44,13.73L14.71,14H15.5L20.5,19L19,20.5L14,15.5V14.71L13.73,14.44C12.59,15.41 11.11,16 9.5,16A6.5,6.5 0 0,1 3,9.5A6.5,6.5 0 0,1 9.5,3M9.5,5C7,5 5,7 5,9.5C5,12 7,14 9.5,14C12,14 14,12 14,9.5C14,7 12,5 9.5,5Z" />
                        </Viewbox>
                        <TextBlock Text="Tra cứu nhanh" Foreground="White" FontFamily="Calibri" FontSize="35" VerticalAlignment="Center" Margin="40,0,0,0"/>
                    </StackPanel>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#cc7274"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#dea2a3"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Click="btnTraCuuLuat_Click" Background="White" Grid.Row="1" BorderThickness="0" VerticalAlignment="Top" Height="80">
                    <StackPanel Orientation="Horizontal" Width="350">
                        <Grid VerticalAlignment="Bottom">
                            <Viewbox Margin="10,0,0,0">
                                <Path Fill="#C62828" Width="35" Height="50" Stretch="Uniform" Data="M760.812 378.812 760.812 414.031 706.188 414.031 706.188 378.812 701.875 378.812 701.875 419.062 727.031 419.062C727.031 420.284 727.966 421.219 729.188 421.219L737.812 421.219C739.034 421.219 739.969 420.284 739.969 419.062L765.125 419.062 765.125 378.812 760.812 378.812Z" />
                            </Viewbox>
                            <Viewbox>
                                <Path Fill="#C62828" Width="30" Height="50" Stretch="Uniform" Data="M1,4 H23 V21 H1 Z M3,19V6H11V19H3M21,19H13V6H21V19M14,9.5H20V11H14V9.5M14,12H20V13.5H14V12M14,14.5H18V16H14V14.5Z" Margin="7.5,0,0,10"/>
                            </Viewbox>
                        </Grid>
                        <TextBlock Text="Tra cứu luật" Foreground="#C62828" FontFamily="Calibri" FontSize="35" VerticalAlignment="Center" Margin="40,0,0,0"/>
                    </StackPanel>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" Background="{TemplateBinding Background}" >
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#cc7274"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#dea2a3"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Click="btnTaiKhoan_Click" Background="#C62828" Grid.Row="2" BorderThickness="0" VerticalAlignment="Top" Height="80">
                    <StackPanel Orientation="Horizontal" Width="350">
                        <Viewbox Width="44" Height="50" Margin="10,0,0,0">
                            <Path Fill="White" Stretch="Uniform" Data="M12,4A4,4 0 0,1 16,8A4,4 0 0,1 12,12A4,4 0 0,1 8,8A4,4 0 0,1 12,4M12,5A3,3 0 0,0 9,8A3,3 0 0,0 12,11A3,3 0 0,0 15,8A3,3 0 0,0 12,5M12,12.2C14.67,12.2 19,13.7 19,17V20H5V17C5,13.7 9.33,12.2 12,12.2M12,13.2C9.5,13.2 6,14.37 6,17V19H18V17C18,14.37 14.5,13.2 12,13.2Z" />
                        </Viewbox>
                        <TextBlock Text="Tài khoản" Foreground="White" FontFamily="Calibri" FontSize="35" VerticalAlignment="Center" Margin="40,0,0,0"/>
                    </StackPanel>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" Background="{TemplateBinding Background}" >
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#cc7274"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#dea2a3"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Click="btnPhanAnh_Click" Background="#C62828" Grid.Row="3" BorderThickness="0" VerticalAlignment="Top" Height="80">
                    <StackPanel Orientation="Horizontal" Width="350">
                        <Viewbox Width="50" Height="50" HorizontalAlignment="Left" Margin="7,0,0,0">
                            <Path Fill="White" Data="M12.5062 12.2188C11.1487 12.2267 10.0546 13.3336 10.0625 14.6912 10.0625 14.6912 10.0625 14.6913 10.0625 14.6913L10.0625 44.505C10.1244 45.7896 11.216 46.7809 12.5006 46.719 12.5024 46.719 12.5044 46.7188 12.5062 46.7188L20.125 46.7188 20.125 56.7812 29.6125 46.7188 56.5944 46.7188C57.8805 46.7267 58.9295 45.6906 58.9375 44.4044 58.9375 44.4044 58.9375 44.4044 58.9375 44.4044L58.9375 14.6913C58.9455 13.3337 57.8514 12.2267 56.4938 12.2188 56.4938 12.2188 56.4937 12.2188 56.4937 12.2188ZM53.9062 33.7812 45.2812 33.7812 45.2812 30.9062 53.9062 30.9062ZM40.25 36.6562 53.9062 36.6562 53.9062 39.5312 40.25 39.5312ZM29.4688 36.6562 37.375 36.6562 37.375 39.5312 29.4688 39.5312ZM27.3125 30.9062 41.6875 30.9062 41.6875 33.7812 27.3125 33.7812ZM18.6875 36.6562 26.5938 36.6562 26.5938 39.5312 18.6875 39.5312ZM15.0938 30.9062 24.4375 30.9062 24.4375 33.7812 15.0938 33.7812Z" />
                        </Viewbox>
                        <TextBlock Text="Phản ánh" Foreground="White" FontFamily="Calibri" FontSize="35" VerticalAlignment="Center" Margin="40,0,0,0"/>
                    </StackPanel>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" Background="{TemplateBinding Background}" >
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#cc7274"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#dea2a3"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Click="btnLichSu_Click" Background="#C62828" Grid.Row="4" BorderThickness="0" VerticalAlignment="Top" Height="80">
                    <StackPanel Orientation="Horizontal" Width="350">
                        <Viewbox Width="44" Height="50" Margin="10,0,0,0">
                            <Path Fill="White" Stretch="Uniform" Data="M13.5,8H12V13L16.28,15.54L17,14.33L13.5,12.25V8M13,3A9,9 0 0,0 4,12H1L4.96,16.03L9,12H6A7,7 0 0,1 13,5A7,7 0 0,1 20,12A7,7 0 0,1 13,19C11.07,19 9.32,18.21 8.06,16.94L6.64,18.36C8.27,20 10.5,21 13,21A9,9 0 0,0 22,12A9,9 0 0,0 13,3" />
                        </Viewbox>
                        <TextBlock Text="Lịch sử" Foreground="White" FontFamily="Calibri" FontSize="35" VerticalAlignment="Center" Margin="40,0,0,0"/>
                    </StackPanel>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" Background="{TemplateBinding Background}" >
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#cc7274"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#dea2a3"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Click="btnThongKe_Click" Background="#C62828" Grid.Row="5" BorderThickness="0" VerticalAlignment="Top" Height="80">
                    <StackPanel Orientation="Horizontal" Width="350">
                        <Viewbox Width="44" Height="50" Margin="10,0,0,0">
                            <Path Fill="White" Stretch="Uniform" Data="M22,21H2V3H4V19H6V10H10V19H12V6H16V19H18V14H22V21Z" />
                        </Viewbox>
                        <TextBlock Text="Thống kê" Foreground="White" FontFamily="Calibri" FontSize="35" VerticalAlignment="Center" Margin="40,0,0,0"/>
                    </StackPanel>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" Background="{TemplateBinding Background}" >
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#cc7274"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#dea2a3"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="100"/>
                <RowDefinition Height="80"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#c72421" Margin="-370,0,0,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" Opacity="0.7" ShadowDepth="3" Direction="0"/>
                </Border.Effect>

                <Grid>
                    <StackPanel Orientation="Horizontal" Margin="60,0,0,0" HorizontalAlignment="Left">
                        <Image Source="/Assets/Images/QuocHuy.png" Width="60" Height="60" Margin="0,0,20,0"/>
                        <TextBlock Text="BỘ GIAO THÔNG VẬN TẢI" Foreground="White" FontSize="32" FontFamily="Calibri" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <local:NotificationBellControl x:Name="myBell" Margin="0,0,20,0" />
                        <Button Click="UserButton_Click" Background="Transparent" BorderThickness="0" Cursor="Hand">
                            <StackPanel Orientation="Horizontal">
                                <Viewbox Width="60" Height="60">
                                    <Path Fill="White" Data="M12,19.2C9.5,19.2 7.29,17.92 6,16C6.03,14 10,12.9 12,12.9C14,12.9 17.97,14 18,16C16.71,17.92 14.5,19.2 12,19.2M12,5A3,3 0 0,1 15,8A3,3 0 0,1 12,11A3,3 0 0,1 9,8A3,3 0 0,1 12,5M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12C22,6.47 17.5,2 12,2Z" />
                                </Viewbox>
                                <TextBlock x:Name="txtUserName" Text="Người dùng" Foreground="White" FontFamily="Calibri" FontSize="25" VerticalAlignment="Center" Margin="15,0,10,0"/>
                                <TextBlock Text="&#x2304;" Foreground="White" FontSize="25" VerticalAlignment="Center" Margin="0,0,20,10"/>
                            </StackPanel>
                            <Button.ContextMenu>
                                <ContextMenu x:Name="UserMenu" Style="{StaticResource RedContextMenuStyle}">
                                    <MenuItem Header="Thông tin tài khoản" Style="{StaticResource RedMenuItemStyle}" Click="MenuInfo_Click">
                                        <MenuItem.Icon>
                                            <Viewbox Width="18" Height="18">
                                                <Path Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=MenuItem}}" 
                                Data="M19,3H14.82C14.4,1.84 13.3,1 12,1C10.7,1 9.6,1.84 9.18,3H5A2,2 0 0,0 3,5V19A2,2 0 0,0 5,21H19A2,2 0 0,0 21,19V5A2,2 0 0,0 19,3M12,3A1,1 0 0,1 13,4A1,1 0 0,1 12,5A1,1 0 0,1 11,4A1,1 0 0,1 12,3M19,19H5V5H7V7H17V5H19V19Z"/>
                                            </Viewbox>
                                        </MenuItem.Icon>
                                    </MenuItem>

                                    <Separator x:Name="sep1"/>

                                    <MenuItem Header="Đăng xuất" Style="{StaticResource RedMenuItemStyle}" Click="MenuLogout_Click">
                                        <MenuItem.Icon>
                                            <Viewbox Width="18" Height="18">
                                                <Path Fill="Red" Data="M16,17V14H9V10H16V7L21,12L16,17M14,2A2,2 0 0,1 16,4V6H14V4H5V20H14V18H16V20A2,2 0 0,1 14,22H5A2,2 0 0,1 3,20V4A2,2 0 0,1 5,2H14Z"/>
                                            </Viewbox>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                </ContextMenu>
                            </Button.ContextMenu>
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="border" Background="{TemplateBinding Background}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="border" Property="Background" Value="#B71C1C"/>
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter TargetName="border" Property="Background" Value="#800000"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Panel.ZIndex="1">
                <TextBlock Grid.Row="0" Text="TRA CỨU LUẬT" FontSize="35" FontFamily="Calibri" Foreground="#333" HorizontalAlignment="Center" Padding="0,35,0,20"/>
            </Grid>
            <Grid Grid.Row="2" Margin="0,0,0,0">
                <Border Background="White" CornerRadius="20" Padding="0" Margin="50,0,30,10">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="40" Opacity="0.3" ShadowDepth="0" Direction="570"/>
                    </Border.Effect>

                    <Grid Margin="30">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Button x:Name="btnBack" Grid.Row="0" Margin="-5,0,0,0" Padding="0" Content="&lt; Quay lại" Foreground="#999" Background="Transparent" BorderThickness="0" HorizontalAlignment="Left" FontSize="16" FontFamily="Calibri" Cursor="Hand" Click="btnBack_Click"/>

                        <Border Grid.Row="1" Background="#FFF5E5" CornerRadius="8" Margin="0,15,0,20" Padding="15">
                            <StackPanel Orientation="Horizontal">
                                <Viewbox Width="24" Height="24" Margin="0,0,10,0">
                                    <Path Fill="#C62828" Data="M13,14H11V10H13M13,18H11V16H13M1,21H23L12,2L1,21Z" />
                                </Viewbox>
                                <TextBlock x:Name="txtTenLoi" Text="Không chấp hành tín hiệu giao thông" FontSize="20" FontFamily="Calibri" Foreground="#333" VerticalAlignment="Center" TextWrapping="Wrap" MaxWidth="800"/>
                            </StackPanel>
                        </Border>

                        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,5,0,5">
                            <TextBlock Text="Nghị định " FontSize="18" FontFamily="Calibri" Foreground="#333" />
                            <TextBlock x:Name="txtNghiDinh" Text="100/2019/NĐ - CP" FontSize="18" FontFamily="Calibri" Foreground="#333"/>
                        </StackPanel>

                        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,5,0,5">
                            <TextBlock Text="Ngày ban hành: " FontSize="18" FontFamily="Calibri" Foreground="#333" />
                            <TextBlock x:Name="txtNgayBanHanh" Text="30/12/2019" FontSize="18" FontFamily="Calibri" Foreground="#333"/>
                        </StackPanel>

                        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,5,0,20">
                            <TextBlock Text="Ngày có hiệu lực: " FontSize="18" FontFamily="Calibri" Foreground="#333" />
                            <TextBlock x:Name="txtNgayHieuLuc" Text="01/01/2020" FontSize="18" FontFamily="Calibri" Foreground="#333"/>
                        </StackPanel>

                        <StackPanel Grid.Row="5" x:Name="spPenalties">
                            <StackPanel Orientation="Horizontal" Margin="0,5,0,5" x:Name="spPhatXeMay">
                                <Ellipse Width="5" Height="5" Fill="#C62828" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="txtPhatXeMay" Text="Phạt tiền từ 600.000 đồng đến 1.000.000 đồng đối với người điều khiển xe mô tô gắn máy" FontSize="18" FontFamily="Calibri" Foreground="#333" TextWrapping="Wrap" MaxWidth="800"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,5,0,5" x:Name="spPhatOto">
                                <Ellipse Width="5" Height="5" Fill="#C62828" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="txtPhatOto" Text="Phạt tiền từ 4.000.000 đồng đến 6.000.000 đồng đối với người điều khiển xe ô tô" FontSize="18" FontFamily="Calibri" Foreground="#333" TextWrapping="Wrap" MaxWidth="800"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,5,0,5" x:Name="spTruDiem">
                                <Ellipse Width="5" Height="5" Fill="#C62828" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="txtTruDiem" Text="Trừ 3 điểm bằng lái xe" FontSize="18" FontFamily="Calibri" Foreground="#333" TextWrapping="Wrap" MaxWidth="800"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                            <Button x:Name="btnChinhSua" Content="Chỉnh sửa" Width="120" Height="40" Background="White" Foreground="Black" BorderBrush="#ccc" BorderThickness="1" FontSize="16" FontFamily="Calibri" Cursor="Hand" Margin="0,0,15,0" Click="btnChinhSua_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <Button x:Name="btnXoaLuat" Content="Xoá luật" Width="120" Height="40" Background="#C62828" Foreground="White" BorderThickness="0" FontSize="16" FontFamily="Calibri" Cursor="Hand" Click="btnXoaLuat_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="borderH" Background="{TemplateBinding Background}" CornerRadius="8">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="borderH" Property="Background" Value="#b32424"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>