<Page x:Class="PBL3.Page38"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:local="clr-namespace:PBL3"
      mc:Ignorable="d"
      d:DesignHeight="792.8" d:DesignWidth="1536"
      Title="OTP" Background="White">

    <Grid>
        <Button Content="&lt; Quay lại" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="30" Background="Transparent" BorderThickness="0" FontSize="20" Cursor="Hand" Click="BtnBack_Click">
            <Button.Style>
                <Style TargetType="Button">
                    <Setter Property="Foreground" Value="Gray"/>

                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border Background="Transparent">
                                    <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                </Border>

                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Foreground" Value="#C62828"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Button.Style>
        </Button>

        <Viewbox Stretch="Uniform" VerticalAlignment="Center" HorizontalAlignment="Center">

            <StackPanel Width="600" Margin="0,80,0,80">
                <TextBlock Text="QUÊN MẬT KHẨU" FontSize="60" FontFamily="Calibri"
                           HorizontalAlignment="Center" Margin="0,0,0,40"/>

                <TextBlock Text="Xác nhận thành công" FontSize="20" Foreground="#8BC34A" FontWeight="Bold" FontFamily="Calibri" HorizontalAlignment="Center" Margin="0,0,0,40"/>

                <TextBlock Text="Đổi mật khẩu" FontSize="16" FontFamily="Calibri" FontWeight="Bold" HorizontalAlignment="Left" Margin="70,0,0,10"/>

                <Border Background="White" CornerRadius="10" Margin="60,0,60,15" Height="45" BorderBrush="#EEE" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="45"/>
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0">
                            <TextBlock x:Name="PasswordPlaceholder" 
                                Text="Nhập mật khẩu mới" 
                                VerticalAlignment="Center" 
                                Foreground="Gray" FontSize="16" FontFamily="Calibri"
                                Margin="15,0,0,0"
                                IsHitTestVisible="False"
                                Panel.ZIndex="0"/>

                            <PasswordBox x:Name="txtNewPassword"
                                VerticalContentAlignment="Center" FontSize="16" FontFamily="Calibri"
                                Padding="15,0"
                                Background="Transparent" 
                                BorderThickness="0"
                                Panel.ZIndex="1"
                                PasswordChanged="PasswordInput_PasswordChanged"/>

                            <TextBox x:Name="txtVisiblePassword"
                                VerticalContentAlignment="Center" FontSize="16" FontFamily="Calibri"
                                Padding="15,0"
                                Background="Transparent" 
                                BorderThickness="0"
                                Panel.ZIndex="1"
                                Visibility="Collapsed"
                                TextChanged="TxtVisiblePassword_TextChanged"/>
                        </Grid>

                        <Button Grid.Column="1" 
                            Background="Transparent" 
                            BorderThickness="0" 
                            Cursor="Hand"
                            Click="BtnToggleEye_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="Transparent">
                                        <Viewbox Width="20" Height="20">
                                            <Path x:Name="IconEye" 
                                                Fill="Gray"
                                                Data="M12,9A3,3 0 0,0 9,12A3,3 0 0,0 12,15A3,3 0 0,0 15,12A3,3 0 0,0 12,9M12,17A5,5 0 0,1 7,12A5,5 0 0,1 12,7A5,5 0 0,1 17,12A5,5 0 0,1 12,17M12,4.5C7,4.5 2.73,7.61 1,12C2.73,16.39 7,19.5 12,19.5C17,19.5 21.27,16.39 23,12C21.27,7.61 17,4.5 12,4.5Z"/>
                                        </Viewbox>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Border>

                <Border Background="White" CornerRadius="10" Margin="60,0,60,20" Height="45" BorderBrush="#EEE" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="45"/>
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0">
                            <TextBlock x:Name="ConfirmPasswordPlaceholder" 
                                Text="Nhập lại mật khẩu" 
                                VerticalAlignment="Center" 
                                Foreground="Gray" FontSize="16" FontFamily="Calibri"
                                Margin="15,0,0,0"
                                IsHitTestVisible="False"
                                Panel.ZIndex="0"/>

                            <PasswordBox x:Name="txtConfirmPassword"
                                VerticalContentAlignment="Center" FontSize="16" FontFamily="Calibri"
                                Padding="15,0"
                                Background="Transparent" 
                                BorderThickness="0"
                                Panel.ZIndex="1"
                                PasswordChanged="ConfirmPasswordInput_PasswordChanged"/>

                            <TextBox x:Name="txtVisibleConfirmPassword"
                                VerticalContentAlignment="Center" FontSize="16" FontFamily="Calibri"
                                Padding="15,0"
                                Background="Transparent" 
                                BorderThickness="0"
                                Panel.ZIndex="1"
                                Visibility="Collapsed"
                                TextChanged="TxtVisibleConfirmPassword_TextChanged"/>
                        </Grid>

                        <Button Grid.Column="1" 
                            Background="Transparent" 
                            BorderThickness="0" 
                            Cursor="Hand"
                            Click="BtnToggleConfirmEye_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="Transparent">
                                        <Viewbox Width="20" Height="20">
                                            <Path x:Name="IconConfirmEye" 
                                                Fill="Gray"
                                                Data="M12,9A3,3 0 0,0 9,12A3,3 0 0,0 12,15A3,3 0 0,0 15,12A3,3 0 0,0 12,9M12,17A5,5 0 0,1 7,12A5,5 0 0,1 12,7A5,5 0 0,1 17,12A5,5 0 0,1 12,17M12,4.5C7,4.5 2.73,7.61 1,12C2.73,16.39 7,19.5 12,19.5C17,19.5 21.27,16.39 23,12C21.27,7.61 17,4.5 12,4.5Z"/>
                                        </Viewbox>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Border>

                <Button Content="Lưu mật khẩu" HorizontalAlignment="Left" Margin="60,0,0,0" Width="150" Background="#C62828" Foreground="White" Height="40" FontSize="16" FontWeight="Bold" FontFamily="Calibri" BorderThickness="0" Cursor="Hand" Click="BtnSavePassword_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Viewbox>
    </Grid>
</Page>