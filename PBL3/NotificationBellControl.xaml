<UserControl x:Class="PBL3.NotificationBellControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PBL3"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid VerticalAlignment="Center">
        <ToggleButton x:Name="btnBell" Width="40" Height="40" Background="Transparent" BorderThickness="0" Cursor="Hand">
            <Path Data="M10 21H14C14 22.1 13.1 23 12 23S10 22.1 10 21M21 19V20H3V19L5 17V11C5 7.9 7 5.2 10 4.3V4C10 2.9 10.9 2 12 2S14 2.9 14 4V4.3C17 5.2 19 7.9 19 11V17L21 19M17 11C17 8.2 14.8 6 12 6S7 8.2 7 11V18H17V11Z" Fill="White" Stretch="Uniform" Margin="7"/>
            <ToggleButton.Template>
                <ControlTemplate TargetType="ToggleButton">
                    <Border Background="{TemplateBinding Background}" CornerRadius="20">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </ToggleButton.Template>
        </ToggleButton>

        <Border Background="#C62828" Width="18" Height="18" CornerRadius="9" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-2,-2,0">
            <TextBlock x:Name="txtUnreadCount" Text="0" Foreground="White" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-1,0,0"/>
        </Border>

        <Popup IsOpen="{Binding IsChecked, ElementName=btnBell}" StaysOpen="False" PlacementTarget="{Binding ElementName=btnBell}" Placement="Bottom" HorizontalOffset="-30" VerticalOffset="0" AllowsTransparency="True">
            <Border Width="360" Background="White" CornerRadius="10" BorderBrush="#E0E0E0" BorderThickness="1" Margin="15">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" Opacity="0.2" ShadowDepth="3" Direction="270"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Thông báo của bạn" FontSize="18" FontWeight="Bold" FontFamily="Calibri" Foreground="#333" Margin="20,0,0,0" VerticalAlignment="Center"/>
                    <Border Grid.Row="0" BorderBrush="#EEEEEE" BorderThickness="0,0,0,1" VerticalAlignment="Bottom"/>

                    <ScrollViewer Grid.Row="1" MaxHeight="400" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="icNotifications">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#EEEEEE" BorderThickness="0,0,0,1" Background="Transparent" Padding="20,15">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0" Width="40" Height="40" CornerRadius="20" Background="#FDEAEA" VerticalAlignment="Top" Margin="0,0,15,0">
                                                <Path Data="M13,9H11V7H13M13,17H11V11H13M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2Z" Fill="#C62828" Stretch="Uniform" Margin="10"/>
                                            </Border>

                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding Content}" FontSize="16" FontFamily="Calibri" TextWrapping="Wrap" Foreground="#333"/>
                                                <TextBlock Text="{Binding Date}" FontSize="14" FontFamily="Calibri" Foreground="#888" Margin="0,5,0,0"/>
                                            </StackPanel>

                                            <Ellipse Grid.Column="2" Width="10" Height="10" Fill="#C62828" Margin="15,0,0,0" VerticalAlignment="Center" Visibility="{Binding UnreadVisibility}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Popup>
    </Grid>
</UserControl>
