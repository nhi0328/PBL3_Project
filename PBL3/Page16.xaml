                </Button>
                <Button Click="btnLBBVP_Click" Background="#C62828" Grid.Row="2" BorderThickness="0" VerticalAlignment="Top" Height="110">
                    <StackPanel Orientation="Horizontal" Width="350">
                        <Viewbox Width="50" Height="50" HorizontalAlignment="Left" Margin="10,0,0,0">
                            <Path Fill="White" Data="M19,3H14.82C14.4,1.84 13.3,1 12,1C10.7,1 9.6,1.84 9.18,3H5A2,2 0 0,0 3,5V19A2,2 0 0,0 5,21H19A2,2 0 0,0 21,19V5A2,2 0 0,0 19,3M12,3A1,1 0 0,1 13,4A1,1 0 0,1 12,5A1,1 0 0,1 11,4A1,1 0 0,1 12,3M7,7H17V5H19V19H5V5H7V7Z" />
                        </Viewbox>
                        <Grid VerticalAlignment="Top">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="55"/>
                                <RowDefinition Height="55"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Lập biên bản" Foreground="White" FontFamily="Calibri" FontSize="35" VerticalAlignment="Center" Margin="40,15,0,0"/>
                            <TextBlock Grid.Row="1" Text="vi phạm" Foreground="White" FontFamily="Calibri" FontSize="35" VerticalAlignment="Center" Margin="40,0,0,15"/>
                        </Grid>
                    </StackPanel>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" Background="{TemplateBinding Background}" >
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#cc7274"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#dea2a3"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Click="btnTaiKhoan_Click" Background="#C62828" Grid.Row="3" BorderThickness="0" VerticalAlignment="Top" Height="80">
                    <StackPanel Orientation="Horizontal" Width="350">
                        <Viewbox Width="44" Height="50" Margin="10,0,0,0">
                            <Path Fill="White" Stretch="Uniform" Data="M12,4A4,4 0 0,1 16,8A4,4 0 0,1 12,12A4,4 0 0,1 8,8A4,4 0 0,1 12,4M12,5A3,3 0 0,0 9,8A3,3 0 0,0 12,11A3,3 0 0,0 15,8A3,3 0 0,0 12,5M12,12.2C14.67,12.2 19,13.7 19,17V20H5V17C5,13.7 9.33,12.2 12,12.2M12,13.2C9.5,13.2 6,14.37 6,17V19H18V17C18,14.37 14.5,13.2 12,13.2Z" />
                        </Viewbox>
                        <TextBlock Text="Tài khoản" Foreground="White" FontFamily="Calibri" FontSize="35" VerticalAlignment="Center" Margin="40,0,0,0"/>
                    </StackPanel>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" Background="{TemplateBinding Background}" >
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#cc7274"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#dea2a3"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Click="btnPhanAnh_Click" Background="White" Grid.Row="4" BorderThickness="0" VerticalAlignment="Top" Height="80">
                    <StackPanel Orientation="Horizontal" Width="350">
                        <Viewbox Width="50" Height="50" HorizontalAlignment="Left" Margin="7,0,0,0">
                            <Path Fill="#C62828" Data="M12.5062 12.2188C11.1487 12.2267 10.0546 13.3336 10.0625 14.6912 10.0625 14.6912 10.0625 14.6913 10.0625 14.6913L10.0625 44.505C10.1244 45.7896 11.216 46.7809 12.5006 46.719 12.5024 46.719 12.5044 46.7188 12.5062 46.7188L20.125 46.7188 20.125 56.7812 29.6125 46.7188 56.5944 46.7188C57.8805 46.7267 58.9295 45.6906 58.9375 44.4044 58.9375 44.4044 58.9375 44.4044 58.9375 44.4044L58.9375 14.6913C58.9455 13.3337 57.8514 12.2267 56.4938 12.2188 56.4938 12.2188 56.4937 12.2188 56.4937 12.2188ZM53.9062 33.7812 45.2812 33.7812 45.2812 30.9062 53.9062 30.9062ZM40.25 36.6562 53.9062 36.6562 53.9062 39.5312 40.25 39.5312ZM29.4688 36.6562 37.375 36.6562 37.375 39.5312 29.4688 39.5312ZM27.3125 30.9062 41.6875 30.9062 41.6875 33.7812 27.3125 33.7812ZM18.6875 36.6562 26.5938 36.6562 26.5938 39.5312 18.6875 39.5312ZM15.0938 30.9062 24.4375 30.9062 24.4375 33.7812 15.0938 33.7812Z" />
                        </Viewbox>
                        <TextBlock Text="Phản ánh" Foreground="#C62828" FontFamily="Calibri" FontSize="35" VerticalAlignment="Center" Margin="40,0,0,0"/>
                    </StackPanel>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" Background="{TemplateBinding Background}" >
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#cc7274"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#dea2a3"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Click="btnLogOut_Click" Background="#C62828" Grid.Row="6" BorderThickness="0" VerticalAlignment="Bottom" Margin="0,0,0,0">
                    <StackPanel Orientation="Horizontal" Width="400">
                        <TextBlock Text="Đăng xuất" Foreground="White" VerticalAlignment="Center" Margin="100,0,0,0" FontSize="30" FontFamily="Calibri"/>
                        <Viewbox Width="35" Height="30" Margin="10,0,0,0">
                            <Path Fill="White" Data="M16,17V14H9V10H16V7L21,12L16,17M14,2A2,2 0 0,1 16,4V9H14V4H5V20H14V15H16V20A2,2 0 0,1 14,22H5A2,2 0 0,1 3,20V4A2,2 0 0,1 5,2H14Z" />
                        </Viewbox>
                    </StackPanel>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" Background="{TemplateBinding Background}" >
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#cc7274"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#dea2a3"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="100"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#c72421" Margin="-370,0,0,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" Opacity="0.7" ShadowDepth="3" Direction="0"/>
                </Border.Effect>

                <Grid>
                    <StackPanel Orientation="Horizontal" Margin="60,0,0,0" HorizontalAlignment="Left">
                        <Image Source="/Assets/Images/QuocHuy.png" Width="60" Height="60" Margin="0,0,20,0"/>
                        <TextBlock Text="BỘ GIAO THÔNG VẬN TẢI" Foreground="White" FontSize="32" FontFamily="Calibri" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <local:NotificationBellControl x:Name="myBell" Margin="0,0,20,0" />
                        <Button Click="UserButton_Click" Background="Transparent" BorderThickness="0" Cursor="Hand">
                            <StackPanel Orientation="Horizontal">
                                <Viewbox Width="60" Height="60">
                                    <Path Fill="White" Data="M12,19.2C9.5,19.2 7.29,17.92 6,16C6.03,14 10,12.9 12,12.9C14,12.9 17.97,14 18,16C16.71,17.92 14.5,19.2 12,19.2M12,5A3,3 0 0,1 15,8A3,3 0 0,1 12,11A3,3 0 0,1 9,8A3,3 0 0,1 12,5M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12C22,6.47 17.5,2 12,2Z" />
                                </Viewbox>
                                <TextBlock x:Name="txtUserName" Text="Người dùng" Foreground="White" FontFamily="Calibri" FontSize="25" VerticalAlignment="Center" Margin="15,0,10,0"/>
                                <TextBlock Text="&#x2304;" Foreground="White" FontSize="25" VerticalAlignment="Center" Margin="0,0,20,10"/>
                            </StackPanel>
                            <Button.ContextMenu>
                                <ContextMenu x:Name="UserMenu" Style="{StaticResource RedContextMenuStyle}">
                                    <MenuItem Header="Thông tin tài khoản" Style="{StaticResource RedMenuItemStyle}" Click="MenuInfo_Click">
                                        <MenuItem.Icon>
                                            <Viewbox Width="18" Height="18">
                                                <Path Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=MenuItem}}" 
                                Data="M19,3H14.82C14.4,1.84 13.3,1 12,1C10.7,1 9.6,1.84 9.18,3H5A2,2 0 0,0 3,5V19A2,2 0 0,0 5,21H19A2,2 0 0,0 21,19V5A2,2 0 0,0 19,3M12,3A1,1 0 0,1 13,4A1,1 0 0,1 12,5A1,1 0 0,1 11,4A1,1 0 0,1 12,3M19,19H5V5H7V7H17V5H19V19Z"/>
                                            </Viewbox>
                                        </MenuItem.Icon>
                                    </MenuItem>

                                    <Separator x:Name="sep1"/>

                                    <MenuItem Header="Đăng xuất" Style="{StaticResource RedMenuItemStyle}" Click="MenuLogout_Click">
                                        <MenuItem.Icon>
                                            <Viewbox Width="18" Height="18">
                                                <Path Fill="Red" Data="M16,17V14H9V10H16V7L21,12L16,17M14,2A2,2 0 0,1 16,4V6H14V4H5V20H14V18H16V20A2,2 0 0,1 14,22H5A2,2 0 0,1 3,20V4A2,2 0 0,1 5,2H14Z"/>
                                            </Viewbox>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                </ContextMenu>
                            </Button.ContextMenu>
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="border" Background="{TemplateBinding Background}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="border" Property="Background" Value="#B71C1C"/>
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter TargetName="border" Property="Background" Value="#800000"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Panel.ZIndex="1">

                <StackPanel>
                    <TextBlock Text="DANH SÁCH PHẢN ÁNH" FontSize="35" FontFamily="Calibri" Foreground="#333" HorizontalAlignment="Center" Padding="0,35,0,20"/>

                    <Border Background="White" Height="550" CornerRadius="10" Padding="0" Margin="50,0,30,10">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="40" Opacity="0.3" ShadowDepth="0" Direction="270"/>
                        </Border.Effect>

                        <Grid Margin="20">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <!-- Top Bar -->
                            <Grid Grid.Row="0" Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="160"/>
                                </Grid.ColumnDefinitions>

                                <!-- Search -->
                                <Border Grid.Column="0" BorderBrush="#ccc" BorderThickness="1" CornerRadius="5" Height="40" Background="White" Margin="0,0,10,0">
                                    <Grid>
                                        <TextBox x:Name="txtSearch" VerticalAlignment="Center" Margin="10,0" BorderThickness="0" FontSize="16" FontFamily="Calibri" Text="Tìm kiếm phản ánh..." Foreground="Gray" GotFocus="txtSearch_GotFocus" LostFocus="txtSearch_LostFocus"/>
                                    </Grid>
                                </Border>
                                <Button Grid.Column="1" Background="#C62828" Foreground="White" FontSize="16" FontFamily="Calibri" Height="40" Padding="15,0" BorderThickness="0" Margin="0,0,20,0" Cursor="Hand" Click="btnSearch_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Fill="White" Data="M9.5,3A6.5,6.5 0 0,1 16,9.5C16,11.11 15.41,12.59 14.44,13.73L14.71,14H15.5L20.5,19L19,20.5L14,15.5V14.71L13.73,14.44C12.59,15.41 11.11,16 9.5,16A6.5,6.5 0 0,1 3,9.5A6.5,6.5 0 0,1 9.5,3M9.5,5C7,5 5,7 5,9.5C5,12 7,14 9.5,14C12,14 14,12 14,9.5C14,7 12,5 9.5,5Z" Width="16" Height="16" Stretch="Uniform" Margin="0,0,5,0"/>
                                        <TextBlock Text="Tìm kiếm" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="5">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>

                                <!-- Filter -->
                                <ComboBox x:Name="cbFilter" Grid.Column="2" Width="100" Height="40" FontSize="16" FontFamily="Calibri" VerticalContentAlignment="Center" Margin="0,0,10,0" SelectionChanged="cbFilter_SelectionChanged">
                                    <ComboBoxItem Content="Tất cả" IsSelected="True"/>
                                    <ComboBoxItem Content="Tai nạn"/>
                                    <ComboBoxItem Content="Vi phạm"/>
                                </ComboBox>
                                <Button x:Name="btnChuaXuLy" Grid.Column="3" Background="#C62828" Foreground="White" FontSize="16" FontFamily="Calibri" Height="40" Padding="15,0" BorderThickness="0" Cursor="Hand" Click="btnChuaXuLy_Click">
                                    <TextBlock x:Name="txtChuaXuLy" Text="Chưa xử lý (0)"/>
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="5">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>

                            <!-- DataGrid -->
                            <DataGrid Grid.Row="1" x:Name="dgComplaints" VerticalScrollBarVisibility="Auto" AutoGenerateColumns="False" CanUserAddRows="False" Background="White" RowHeight="40" ColumnHeaderHeight="40" HeadersVisibility="Column" HorizontalGridLinesBrush="#eee" VerticalGridLinesBrush="#ccc" BorderBrush="#ccc" BorderThickness="1" IsReadOnly="True" FontSize="14" FontFamily="Calibri">
                                <DataGrid.Resources>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="#f5f5f5"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                                        <Setter Property="BorderBrush" Value="#ccc"/>
                                        <Setter Property="Padding" Value="10,0"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                    </Style>
                                    <Style TargetType="DataGridCell">
                                        <Setter Property="TextBlock.TextAlignment" Value="Center"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="DataGridCell">
                                                    <Border BorderThickness="0,0,1,1" BorderBrush="#ccc" Background="Transparent" Padding="10,0">
                                                        <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </DataGrid.Resources>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="STT" Binding="{Binding STT}" Width="60"/>
                                    <DataGridTextColumn Header="CCCD" Binding="{Binding CCCD}" Width="150"/>
                                    <DataGridTextColumn Header="Loại phản ánh" Binding="{Binding LoaiPhanAnh}" Width="*"/>
                                    <DataGridTextColumn Header="Tiêu đề" Binding="{Binding TieuDe}" Width="*"/>
                                    <DataGridTextColumn Header="Ngày gửi" Binding="{Binding SubmittedDate, StringFormat=dd/MM/yyyy}" Width="120"/>
                                    <DataGridTemplateColumn Header="Hành động" Width="120">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border Background="{Binding StatusColor}" CornerRadius="5" Padding="10,5" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Status}" Foreground="White" FontWeight="Bold"/>
                                                </Border>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="Xem chi tiết" Width="100">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="Chi tiết" Background="White" BorderBrush="#ccc" BorderThickness="1" Padding="10,2" Foreground="#333" Cursor="Hand" Click="BtnDetails_Click" Tag="{Binding ComplaintId}">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="5">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>

                            <!-- Pagination -->
                            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0"/>

                        </Grid>
                    </Border>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Page>
