                                    <MenuItem Header="Đăng xuất" Style="{StaticResource RedMenuItemStyle}" Click="MenuLogout_Click">
                                        <MenuItem.Icon>
                                            <Viewbox Width="18" Height="18">
                                                <Path Fill="Red" Data="M16,17V14H9V10H16V7L21,12L16,17M14,2A2,2 0 0,1 16,4V6H14V4H5V20H14V18H16V20A2,2 0 0,1 14,22H5A2,2 0 0,1 3,20V4A2,2 0 0,1 5,2H14Z"/>
                                            </Viewbox>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                </ContextMenu>
                            </Button.ContextMenu>
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="border" Background="{TemplateBinding Background}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="border" Property="Background" Value="#B71C1C"/>
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter TargetName="border" Property="Background" Value="#800000"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Panel.ZIndex="1">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="LUẬT" FontSize="35" FontFamily="Calibri" Foreground="#333" HorizontalAlignment="Center" Padding="0,35,0,20"/>

                    <Border Grid.Row="1" Background="White" CornerRadius="20" Padding="0" Margin="50,0,30,30">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="40" Opacity="0.3" ShadowDepth="0" Direction="570"/>
                        </Border.Effect>

                        <Grid Margin="20">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Height="50" Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="150"/>
                                </Grid.ColumnDefinitions>

                                <Border CornerRadius="8" BorderBrush="#CCC" BorderThickness="1" Background="#FAFAFA" Grid.Column="0">
                                    <TextBox VerticalContentAlignment="Center" FontSize="20"
                                        Background="Transparent" BorderThickness="0" Foreground="#333" 
                                            x:Name="txtIdentifier" TextChanged="txtIdentifier_TextChanged">
                                        <TextBox.Resources>
                                            <Style TargetType="{x:Type TextBox}">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="{x:Type TextBox}">
                                                            <Grid Margin="15,0,0,0">
                                                                <ScrollViewer x:Name="PART_ContentHost"/>
                                                                <TextBlock Text="Tìm kiếm luật hoặc lỗi vi phạm giao thông..." x:Name="UserPlaceholder" 
                                                                    Foreground="Gray" VerticalAlignment="Center" 
                                                                    IsHitTestVisible="False"
                                                                    Visibility="Collapsed"/>
                                                            </Grid>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="Text" Value="">
                                                                    <Setter TargetName="UserPlaceholder" Property="Visibility" Value="Visible"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </TextBox.Resources>
                                    </TextBox>
                                </Border>

                                <Button Grid.Column="1" Margin="15,0,0,0" Background="#C62828" Cursor="Hand" Click="btnSearch_Click">
                                    <StackPanel Orientation="Horizontal" Width="130" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Viewbox Width="25" Height="25" HorizontalAlignment="Left" Margin="10,0,0,0">
                                            <Path Fill="White" Data="M9.5,3A6.5,6.5 0 0,1 16,9.5C16,11.11 15.41,12.59 14.44,13.73L14.71,14H15.5L20.5,19L19,20.5L14,15.5V14.71L13.73,14.44C12.59,15.41 11.11,16 9.5,16A6.5,6.5 0 0,1 3,9.5A6.5,6.5 0 0,1 9.5,3M9.5,5C7,5 5,7 5,9.5C5,12 7,14 9.5,14C12,14 14,12 14,9.5C14,7 12,5 9.5,5Z" />
                                        </Viewbox>
                                        <TextBlock Text="Tra cứu" FontSize="20" FontFamily="Calibri" VerticalAlignment="Center" Margin="5,0,0,0" Foreground="White" />
                                    </StackPanel>

                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>

                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="border" Property="Background" Value="#B71C1C"/>
                                                            </Trigger>
                                                            <Trigger Property="IsPressed" Value="True">
                                                                <Setter TargetName="border" Property="Background" Value="#800000"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                </Button>

                                <Button Grid.Column="2" Margin="15,0,0,0" Background="#C62828" Cursor="Hand" Click="btnThemLuat_Click">
                                    <TextBlock Text="+ Thêm luật" FontSize="20" FontFamily="Calibri" VerticalAlignment="Center" Foreground="White" />
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="border" Property="Background" Value="#B71C1C"/>
                                                            </Trigger>
                                                            <Trigger Property="IsPressed" Value="True">
                                                                <Setter TargetName="border" Property="Background" Value="#800000"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </Grid>
                            <Border Grid.Row="1" CornerRadius="10" Background="White">
                                <ListView x:Name="dgvDanhSachLuat" Background="Transparent"  BorderThickness="0" HorizontalContentAlignment="Stretch" ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListView.ItemContainerStyle>
                                        <Style TargetType="ListViewItem">
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListViewItem">
                                                        <ContentPresenter />
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ListView.ItemContainerStyle>

                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="#DDD" BorderThickness="1" CornerRadius="8" Margin="0,0,10,10" Background="White">
                                                <Expander Style="{StaticResource RightArrowExpanderStyle}" Header="{Binding TenLoi}" Background="White">

                                                    <Grid Margin="45,10,20,15">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>

                                                        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,5" Visibility="{Binding HasPhatTienOto, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                            <Ellipse Width="8" Height="8" Fill="#C62828" Margin="0,8,10,0" VerticalAlignment="Top"/>
                                                            <TextBlock Text="Phạt tiền ô tô: " FontSize="18" FontFamily="Calibri" FontWeight="Bold"/>
                                                            <TextBlock Text="{Binding PhatTienOto}" FontSize="18" FontFamily="Calibri"/>
                                                        </StackPanel>

                                                        <StackPanel Orientation="Horizontal" Grid.Row="1" Margin="0,5" Visibility="{Binding HasPhatTienXeMay, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                            <Ellipse Width="8" Height="8" Fill="#C62828" Margin="0,8,10,0" VerticalAlignment="Top"/>
                                                            <TextBlock Text="Phạt tiền xe máy: " FontSize="18" FontFamily="Calibri" FontWeight="Bold"/>
                                                            <TextBlock Text="{Binding PhatTienXeMay}" FontSize="18" FontFamily="Calibri"/>
                                                        </StackPanel>

                                                        <StackPanel Orientation="Horizontal" Grid.Row="2" Margin="0,5" Visibility="{Binding HasTruDiem, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                            <Ellipse Width="8" Height="8" Fill="#C62828" Margin="0,8,10,0" VerticalAlignment="Top"/>
                                                            <TextBlock Text="Hình phạt bổ sung: " FontSize="18" FontFamily="Calibri" FontWeight="Bold"/>
                                                            <TextBlock Text="{Binding TruDiem}" FontSize="18" FontFamily="Calibri"/>
                                                        </StackPanel>

                                                        <Button Grid.Row="3" Content="Xem chi tiết" HorizontalAlignment="Right" Foreground="#C62828" FontFamily="Calibri" FontSize="18" Padding="15,5" Margin="0,10,0,0" Cursor="Hand" Click="btnXemChiTiet_Click">
                                                            <Button.Style>
                                                                <Style TargetType="Button">
                                                                    <Setter Property="Background" Value="White"/>
                                                                    <Setter Property="BorderBrush" Value="#CCC"/>
                                                                    <Setter Property="BorderThickness" Value="1"/>
                                                                    <Setter Property="Template">
                                                                        <Setter.Value>
                                                                            <ControlTemplate TargetType="Button">
                                                                                <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="5">
                                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                                                                                </Border>
                                                                                <ControlTemplate.Triggers>
                                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                                        <Setter TargetName="border" Property="Background" Value="#CCC"/>
                                                                                    </Trigger>
                                                                                    <Trigger Property="IsPressed" Value="True">
                                                                                        <Setter TargetName="border" Property="Background" Value="#AAA"/>
                                                                                    </Trigger>
                                                                                </ControlTemplate.Triggers>
                                                                            </ControlTemplate>
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                </Style>
                                                            </Button.Style>
                                                        </Button>
                                                    </Grid>
                                                </Expander>
                                            </Border>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Page>
