                                        <MenuItem.Icon>
                                            <Viewbox Width="18" Height="18">
                                                <Path Fill="Red" Data="M16,17V14H9V10H16V7L21,12L16,17M14,2A2,2 0 0,1 16,4V6H14V4H5V20H14V18H16V20A2,2 0 0,1 14,22H5A2,2 0 0,1 3,20V4A2,2 0 0,1 5,2H14Z"/>
                                            </Viewbox>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                </ContextMenu>
                            </Button.ContextMenu>
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="border" Background="{TemplateBinding Background}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="border" Property="Background" Value="#B71C1C"/>
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter TargetName="border" Property="Background" Value="#800000"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Panel.ZIndex="1" Background="#F2F2F2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="100"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,12,0,10">
                    <TextBlock Text="LẬP BIÊN BẢN VI PHẠM" FontSize="28" FontFamily="Calibri" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>

                <Border Grid.Row="1" Background="White" CornerRadius="18" Padding="24" Margin="35,0,35,25">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="28" Opacity="0.18" ShadowDepth="2" Direction="270"/>
                    </Border.Effect>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="18"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="18"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="18"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="18"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.1*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="3.4*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Chọn loại phương tiện" Style="{StaticResource FormLabelStyle}"/>
                                    <ComboBox x:Name="cmbVehicleType" Style="{StaticResource FormComboBoxStyle}" SelectedIndex="0" IsEditable="True" IsTextSearchEnabled="False" StaysOpenOnEdit="True" Background="White" Foreground="Black" SelectionChanged="cmbVehicleType_SelectionChanged">
                                    </ComboBox>
                                </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Biển số xe" Style="{StaticResource FormLabelStyle}"/>
                                <TextBox x:Name="txtLicensePlate" Style="{StaticResource FormInputStyle}" Text="" Foreground="#333">
                                    <TextBox.Resources>
                                        <Style TargetType="{x:Type TextBox}">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="{x:Type TextBox}">
                                                        <Grid>
                                                            <ScrollViewer x:Name="PART_ContentHost" Margin="14,0,14,0" VerticalAlignment="Center"/>
                                                            <TextBlock x:Name="LicensePlatePlaceholder"
                                                                       Text="Ví dụ: 30A-123.45"
                                                                       Foreground="Gray"
                                                                       Margin="14,0,14,0"
                                                                       VerticalAlignment="Center"
                                                                       IsHitTestVisible="False"
                                                                       Visibility="Collapsed"/>
                                                        </Grid>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="Text" Value="">
                                                                <Setter TargetName="LicensePlatePlaceholder" Property="Visibility" Value="Visible"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </TextBox.Resources>
                                </TextBox>
                            </StackPanel>
                        </Grid>

                        <StackPanel Grid.Row="2">
                            <TextBlock Text="Lỗi vi phạm" Style="{StaticResource FormLabelStyle}"/>
                            <ComboBox x:Name="cmbViolationType"
                                      Style="{StaticResource FormComboBoxStyle}"
                                      SelectedIndex="0"
                                      IsEditable="True"
                                      IsTextSearchEnabled="False"
                                      StaysOpenOnEdit="True"
                                      MaxDropDownHeight="240"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                      SelectionChanged="cmbViolationType_SelectionChanged"
                                      PreviewKeyDown="cmbViolationType_PreviewKeyDown">
                            </ComboBox>
                            <WrapPanel x:Name="SelectedViolationsPanel" Margin="0,12,0,0"/>
                        </StackPanel>

                        <Grid Grid.Row="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.15*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="0.95*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="3.2*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Ngày vi phạm" Style="{StaticResource FormLabelStyle}"/>
                                <Border Background="White" CornerRadius="10" BorderBrush="#EEE" BorderThickness="1" Height="40">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="10" Opacity="0.1" ShadowDepth="2"/>
                                    </Border.Effect>
                                    <Grid>
                                        <Grid Margin="15,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock x:Name="txtDateDisplay" FontFamily="Calibri" FontSize="20" Text="dd/mm/yyyy" VerticalAlignment="Center" Foreground="Gray"/>
                                            <Viewbox Grid.Column="1" Width="30" Height="30" HorizontalAlignment="Right">
                                                <Path Data="M19,19H5V8H19M16,1V3H8V1H6V3H5C3.89,3 3,3.89 3,5V19A2,2 0 0,0 5,21H19A2,2 0 0,0 21,19V5C21,3.89 20.1,3 19,1H18V3H16V1M17,12H12V17H17V12Z" Fill="#C62828"/>
                                            </Viewbox>
                                        </Grid>
                                        <DatePicker x:Name="RealDatePicker" SelectedDateChanged="RealDatePicker_SelectedDateChanged" CalendarClosed="RealDatePicker_CalendarClosed" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Opacity="0" IsHitTestVisible="False"/>
                                        <Border x:Name="DateOverlay" Background="Transparent" Cursor="Hand" MouseLeftButtonDown="DateOverlay_Click"/>
                                    </Grid>
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Giờ vi phạm" Style="{StaticResource FormLabelStyle}"/>
                                <TextBox x:Name="txtViolationTime" Style="{StaticResource FormInputStyle}" Text=""/>
                            </StackPanel>

                            <StackPanel Grid.Column="4">
                                <TextBlock Text="Địa điểm vi phạm" Style="{StaticResource FormLabelStyle}"/>
                                <TextBox x:Name="txtViolationLocation" Style="{StaticResource FormInputStyle}" Text=""/>
                            </StackPanel>
                        </Grid>

                        <StackPanel Grid.Row="6">
                            <TextBlock Text="M&#xF4; t&#x1EA3; vi ph&#x1EA1;m" Style="{StaticResource FormLabelStyle}"/>
                            <TextBox x:Name="txtViolationDescription" Style="{StaticResource FormInputStyle}" Height="80" TextWrapping="Wrap" AcceptsReturn="True" Text=""/>
                        </StackPanel>

                        <StackPanel Grid.Row="8">
                            <TextBlock Text="Hình ảnh" Style="{StaticResource FormLabelStyle}"/>
                            <Grid Height="120" Cursor="Hand" MouseLeftButtonUp="UploadEvidenceArea_MouseLeftButtonUp">
                                <Rectangle RadiusX="6" RadiusY="6" Stroke="#9A9A9A" StrokeThickness="1" StrokeDashArray="3,2" Fill="Transparent"/>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="24,0,0,0">
                                    <Border Width="42" Height="42" Background="#8F8A8A" CornerRadius="4" VerticalAlignment="Center">
                                        <TextBlock Text="📷" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center" Margin="0,7,0,0"/>
                                    </Border>
                                    <StackPanel Margin="18,0,0,0" VerticalAlignment="Center">
                                        <TextBlock x:Name="txtEvidenceFileName" Text="+ T&#x1EA3;i h&#xEC;nh &#x1EA3;nh l&#xEA;n" FontFamily="Calibri" FontSize="16" Foreground="#7A7A7A"/>
                                        <TextBlock x:Name="txtEvidenceStatus" Text="T&#x1ED1;i &#x111;a 5 &#x1EA3;nh" FontFamily="Calibri" FontSize="14" Foreground="#9A9A9A"/>
                                        <TextBlock Text="&#x110;&#x1ECB;nh d&#x1EA1;ng: JPG, JPEG, PNG" FontFamily="Calibri" FontSize="14" Foreground="#9A9A9A"/>
                                        <TextBlock Text="Dung l&#x1B0;&#x1EE3;ng t&#x1ED1;i &#x111;a 10MB" FontFamily="Calibri" FontSize="14" Foreground="#9A9A9A"/>
                                    </StackPanel>
                                    <Border Width="110" Height="80" Margin="24,0,0,0" Background="#F6F6F6" BorderBrush="#D6D6D6" BorderThickness="1" CornerRadius="8">
                                        <Grid>
                                            <Image x:Name="imgEvidencePreview" Stretch="UniformToFill" Visibility="Collapsed"/>
                                            <TextBlock x:Name="txtEvidencePreviewPlaceholder" Text="Xem tr&#x1B0;&#x1EDB;c" FontFamily="Calibri" FontSize="14" Foreground="#9A9A9A" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </StackPanel>

                        <StackPanel Grid.Row="10" Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Content="Lưu vi phạm" Background="#C62828" Style="{StaticResource PrimaryActionButtonStyle}" Click="BtnSave_Click" Margin="0,0,12,0"/>
                            <Button Content="Hủy" Style="{StaticResource SecondaryActionButtonStyle}" Click="BtnCancel_Click"/>
                        </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>
