                <Button Click="btnNLVP_Click" Background="White" Grid.Row="2" BorderThickness="0" VerticalAlignment="Top" Height="110">
                    <StackPanel Orientation="Horizontal" Width="350">
                        <Viewbox Width="50" Height="50" HorizontalAlignment="Left" Margin="10,0,0,0">
                            <Path Fill="#C62828" Data="M19,3H14.82C14.4,1.84 13.3,1 12,1C10.7,1 9.6,1.84 9.18,3H5A2,2 0 0,0 3,5V19A2,2 0 0,0 5,21H19A2,2 0 0,0 21,19V5A2,2 0 0,0 19,3M12,3A1,1 0 0,1 13,4A1,1 0 0,1 12,5A1,1 0 0,1 11,4A1,1 0 0,1 12,3M7,7H17V5H19V19H5V5H7V7Z" />
                        </Viewbox>
                        <Grid VerticalAlignment="Top">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="55"/>
                                <RowDefinition Height="55"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Lập biên bản" Foreground="#C62828" FontFamily="Calibri" FontSize="35" VerticalAlignment="Center" Margin="40,15,0,0"/>
