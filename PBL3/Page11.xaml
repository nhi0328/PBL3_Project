<Page x:Class="PBL3.Page11"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PBL3"
        mc:Ignorable="d"
        Title="Tra cứu luật" 
        d:DesignHeight="792.8" d:DesignWidth="1536"
        Background="White">
    <Grid>
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="100"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#c72421">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" Opacity="0.7" ShadowDepth="3" Direction="0"/>
                </Border.Effect>

                <Grid>
                    <StackPanel Orientation="Horizontal" Margin="60,0,0,0" HorizontalAlignment="Left">
                        <Image Source="/Assets/Images/QuocHuy.png" Width="60" Height="60" Margin="0,0,20,0"/>
                        <TextBlock Text="BỘ GIAO THÔNG VẬN TẢI" Foreground="White" FontSize="32" FontFamily="Calibri" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Panel.ZIndex="1">
                <Button Content="&lt; Quay lại" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="30" Background="Transparent" BorderThickness="0" FontSize="20" Cursor="Hand" Click="BtnBack_Click"/>

                <Grid Margin="0,30,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="TRA CỨU LUẬT" FontSize="35" FontFamily="Calibri" Foreground="#333" HorizontalAlignment="Center" Padding="0,5,0,20"/>

                    <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="0" Margin="250,0,250,10">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="40" Opacity="0.3" ShadowDepth="0" Direction="570"/>
                        </Border.Effect>

                        <Grid Margin="20">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Height="50" Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="150"/>
                                </Grid.ColumnDefinitions>

                                <Border CornerRadius="8" BorderBrush="#CCC" BorderThickness="1" Background="#FAFAFA">
                                    <TextBox Grid.Column="1" VerticalContentAlignment="Center" FontSize="20"
                                        Background="Transparent" BorderThickness="0" Foreground="#333" 
                                            x:Name="txtIdentifier" TextChanged="txtIdentifier_TextChanged">
                                        <TextBox.Resources>
                                            <Style TargetType="{x:Type TextBox}">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="{x:Type TextBox}">
                                                            <Grid Margin="10">
                                                                <ScrollViewer x:Name="PART_ContentHost"/>
                                                                <TextBlock Text="Tìm kiếm luật hoặc lỗi vi phạm giao thông..." x:Name="UserPlaceholder" 
                                                                    Foreground="Gray" VerticalAlignment="Center" 
                                                                    IsHitTestVisible="False"
                                                                    Visibility="Collapsed"/>
                                                            </Grid>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="Text" Value="">
                                                                    <Setter TargetName="UserPlaceholder" Property="Visibility" Value="Visible"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </TextBox.Resources>
                                    </TextBox>
                                </Border>

                                <Button Grid.Column="1" Margin="15,0,0,0" Background="#C62828" Cursor="Hand" Click="BtnSearch_Click">
                                    <StackPanel Orientation="Horizontal" Width="130" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Viewbox Width="25" Height="25" HorizontalAlignment="Left" Margin="10,0,0,0">
                                            <Path Fill="White" Data="M9.5,3A6.5,6.5 0 0,1 16,9.5C16,11.11 15.41,12.59 14.44,13.73L14.71,14H15.5L20.5,19L19,20.5L14,15.5V14.71L13.73,14.44C12.59,15.41 11.11,16 9.5,16A6.5,6.5 0 0,1 3,9.5A6.5,6.5 0 0,1 9.5,3M9.5,5C7,5 5,7 5,9.5C5,12 7,14 9.5,14C12,14 14,12 14,9.5C14,7 12,5 9.5,5Z" />
                                        </Viewbox>
                                        <TextBlock Text="Tra cứu" FontSize="25" FontFamily="Calibri" VerticalAlignment="Center" Margin="10,0,0,0" Foreground="White" />
                                    </StackPanel>

                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>

                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="border" Property="Background" Value="#B71C1C"/>
                                                            </Trigger>
                                                            <Trigger Property="IsPressed" Value="True">
                                                                <Setter TargetName="border" Property="Background" Value="#800000"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </Grid>
                            <Border Grid.Row="1" Background="White" Padding="0" CornerRadius="10">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                    <ScrollViewer.Resources>
                                        <Style TargetType="ScrollBar">
                                            <Setter Property="Width" Value="8"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ScrollBar">
                                                        <Grid Background="Transparent">
                                                            <Border x:Name="Bg" Background="Transparent"/>
                                                            <Track x:Name="PART_Track" IsDirectionReversed="true" IsEnabled="{TemplateBinding IsMouseOver}">
                                                                <Track.Thumb>
                                                                    <Thumb>
                                                                        <Thumb.Template>
                                                                            <ControlTemplate TargetType="Thumb">
                                                                                <Border CornerRadius="4" Background="#CCC" Margin="0,0,0,0"/>
                                                                            </ControlTemplate>
                                                                        </Thumb.Template>
                                                                    </Thumb>
                                                                </Track.Thumb>
                                                            </Track>
                                                        </Grid>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ScrollViewer.Resources>
                                    <!-- ItemsControl for Laws -->
                                    <ItemsControl x:Name="icLaws">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" Background="White" Margin="0,0,0,10">

                                                    <Expander Background="White">
                                                        <Expander.Style>
                                                            <Style TargetType="Expander">
                                                                <Setter Property="Template">
                                                                    <Setter.Value>
                                                                        <ControlTemplate TargetType="Expander">
                                                                            <Border CornerRadius="8" Background="{TemplateBinding Background}">
                                                                                <DockPanel>
                                                                                    <ToggleButton x:Name="HeaderSite" DockPanel.Dock="Top" Cursor="Hand" IsChecked="{Binding IsExpanded, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                                                                        <ToggleButton.Template>
                                                                                            <ControlTemplate TargetType="ToggleButton">
                                                                                                <Border x:Name="HeaderBorder" Background="Transparent" CornerRadius="8">
                                                                                                    <Grid Margin="10,10,0,10">
                                                                                                        <Grid.ColumnDefinitions>
                                                                                                            <ColumnDefinition Width="Auto"/>
                                                                                                            <ColumnDefinition Width="*"/>
                                                                                                            <ColumnDefinition Width="Auto"/>
                                                                                                        </Grid.ColumnDefinitions>

                                                                                                        <Path Grid.Column="0" Data="M12 2L2 22H22L12 2ZM11 10H13V15H11V10ZM11 17H13V19H11V17Z" Fill="#C62828" Width="24" Height="24" Stretch="Uniform" Margin="0,0,10,0"/>
                                                                                                        <ContentPresenter Grid.Column="1" ContentSource="Content" VerticalAlignment="Center" HorizontalAlignment="Left" />

                                                                                                        <TextBlock x:Name="Arrow" Grid.Column="2" Text="v" FontFamily="Century Gothic" FontWeight="Bold" Foreground="#333" FontSize="18" Margin="0,0,15,0" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                                                                                                            <TextBlock.RenderTransform>
                                                                                                                <RotateTransform Angle="0"/>
                                                                                                            </TextBlock.RenderTransform>
                                                                                                        </TextBlock>
                                                                                                    </Grid>
                                                                                                </Border>
                                                                                                <ControlTemplate.Triggers>
                                                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                                                        <Setter TargetName="HeaderBorder" Property="Background" Value="#F0F0F0"/>
                                                                                                    </Trigger>
                                                                                                    <DataTrigger Binding="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}" Value="True">
                                                                                                        <Setter TargetName="Arrow" Property="RenderTransform">
                                                                                                            <Setter.Value>
                                                                                                                <RotateTransform Angle="180"/>
                                                                                                            </Setter.Value>
                                                                                                        </Setter>
                                                                                                    </DataTrigger>
                                                                                                </ControlTemplate.Triggers>
                                                                                            </ControlTemplate>
                                                                                        </ToggleButton.Template>
                                                                                        <ToggleButton.Content>
                                                                                            <TextBlock Text="{Binding Name}" FontSize="22" Foreground="#333" TextWrapping="Wrap" />
                                                                                        </ToggleButton.Content>
                                                                                    </ToggleButton>

                                                                                    <ContentPresenter x:Name="ExpandSite" Visibility="Collapsed" Content="{TemplateBinding Content}" Margin="45,0,20,20"/>
                                                                                </DockPanel>
                                                                            </Border>
                                                                            <ControlTemplate.Triggers>
                                                                                <Trigger Property="IsExpanded" Value="True">
                                                                                    <Setter TargetName="ExpandSite" Property="Visibility" Value="Visible"/>
                                                                                </Trigger>
                                                                            </ControlTemplate.Triggers>
                                                                        </ControlTemplate>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </Style>
                                                        </Expander.Style>

                                                        <StackPanel>
                                                            <Path Data="M0,0 L1000,0" Stretch="Fill" Stroke="#E0E0E0" StrokeThickness="1" Height="1" Margin="-40,0,0,15"/>
                                                            <ItemsControl ItemsSource="{Binding Details}">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <StackPanel Orientation="Horizontal" Margin="0,5,0,5">
                                                                            <Ellipse Width="6" Height="6" Fill="#C62828" Margin="0,8,10,0" VerticalAlignment="Top"/>
                                                                            <TextBlock Text="{Binding}" FontSize="18" Foreground="#555" TextWrapping="Wrap" MaxWidth="800" TextAlignment="Left"/>
                                                                        </StackPanel>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>

                                                            <Button Content="Xem chi tiết" HorizontalAlignment="Right" Background="White" Foreground="#C62828" BorderBrush="#E0E0E0" BorderThickness="1" Padding="10,5" Cursor="Hand" Margin="0,15,0,0" Tag="{Binding STT}" Click="BtnDetail_Click">
                                                                <Button.Resources>
                                                                    <Style TargetType="Border">
                                                                        <Setter Property="CornerRadius" Value="4"/>
                                                                    </Style>
                                                                </Button.Resources>
                                                            </Button>
                                                        </StackPanel>

                                                    </Expander>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Page>