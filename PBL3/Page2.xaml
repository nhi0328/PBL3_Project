<Page x:Class="PBL3.Page2"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:local="clr-namespace:PBL3"
      mc:Ignorable="d"
      d:DesignHeight="792.8" d:DesignWidth="1536"
      Title="Login" Background="White">

    <Grid>
        <Button Content="&lt; Quay lại" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="30" Background="Transparent" BorderThickness="0" FontSize="20" Cursor="Hand" Click="BtnBack_Click">
            <Button.Style>
                <Style TargetType="Button">
                    <Setter Property="Foreground" Value="Gray"/>

                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border Background="Transparent">
                                    <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                </Border>

                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Foreground" Value="#C62828"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Button.Style>
        </Button>

        <Viewbox Stretch="Uniform" VerticalAlignment="Center" HorizontalAlignment="Center">

            <StackPanel Width="450" Margin="0,80,0,80">

                <TextBlock Text="ĐĂNG NHẬP" FontSize="70" FontFamily="Calibri"
                           HorizontalAlignment="Center" Margin="0,0,0,70"/>

                <Border Background="White" CornerRadius="10" Margin="0,0,0,20" Height="60" BorderBrush="#EEE" BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="20" Opacity="0.1" ShadowDepth="5"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Viewbox Width="40" Height="40" Margin="0,0,10,10">
                            <Path Data="M12,4A4,4 0 0,1 16,8A4,4 0 0,1 12,12A4,4 0 0,1 8,8A4,4 0 0,1 12,4M12,6A2,2 0 0,0 10,8A2,2 0 0,0 12,10A2,2 0 0,0 14,8A2,2 0 0,0 12,6M12,13C14.67,13 20,14.33 20,17V20H4V17C4,14.33 9.33,13 12,13M12,14.9C9.03,14.9 5.9,16.36 5.9,17V18.1H18.1V17C18.1,16.36 14.97,14.9 12,14.9Z" Fill="#C62828"/>
                        </Viewbox>
                        <TextBox Grid.Column="1" VerticalContentAlignment="Center" FontSize="20"
                                 Background="Transparent" BorderThickness="0" Foreground="#333" 
                                 x:Name="txtIdentifier">
                            <TextBox.Resources>
                                <Style TargetType="{x:Type TextBox}">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="{x:Type TextBox}">
                                                <Grid>
                                                    <ScrollViewer x:Name="PART_ContentHost"/>
                                                    <TextBlock Text="Nhập số CCCD" x:Name="UserPlaceholder" 
                                                               Foreground="Gray" VerticalAlignment="Center" 
                                                               IsHitTestVisible="False"
                                                               Visibility="Collapsed"/>
                                                </Grid>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="Text" Value="">
                                                        <Setter TargetName="UserPlaceholder" Property="Visibility" Value="Visible"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </TextBox.Resources>
                        </TextBox>
                    </Grid>
                </Border>

                
                <Border Background="White" CornerRadius="15" Margin="0,0,0,20" Height="60" BorderBrush="#EEE" BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="20" Opacity="0.1" ShadowDepth="5"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="70"/>
                        </Grid.ColumnDefinitions>

                        <Viewbox Width="30" Height="30">
                            <Path Data="M12,17A2,2 0 0,0 14,15C14,13.89 13.11,13 12,13A2,2 0 0,0 10,15A2,2 0 0,0 12,17M18,8H17V6A5,5 0 0,0 12,1A5,5 0 0,0 7,6V8H6A2,2 0 0,0 4,10V20A2,2 0 0,0 6,22H18A2,2 0 0,0 20,20V10A2,2 0 0,0 18,8M9,6A3,3 0 0,1 12,3A3,3 0 0,1 15,6V8H9V6Z" Fill="#C62828"/>
                        </Viewbox>

                        <Grid Grid.Column="1">
                            <TextBlock x:Name="PasswordPlaceholder" 
                                Text="Nhập mật khẩu" 
                                VerticalAlignment="Center" 
                                Foreground="Gray" FontSize="20"
                                IsHitTestVisible="False"
                                Panel.ZIndex="0"/>

                            <PasswordBox x:Name="txtPassword"
                                VerticalContentAlignment="Center" FontSize="20"
                                Background="Transparent" 
                                BorderThickness="0"
                                Panel.ZIndex="1"
                                PasswordChanged="PasswordInput_PasswordChanged"/>
                            
                            <TextBox x:Name="txtVisiblePassword"
                                VerticalContentAlignment="Center" FontSize="20"
                                Background="Transparent" 
                                BorderThickness="0"
                                Panel.ZIndex="1"
                                Visibility="Collapsed"
                                TextChanged="TxtVisiblePassword_TextChanged"/>
                        </Grid>

                        <Button Grid.Column="2" 
                            Background="Transparent" 
                            BorderThickness="0" 
                            Cursor="Hand"
                            Click="BtnToggleEye_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="Transparent">
                                        <Viewbox Width="25" Height="25">
                                            <Path x:Name="IconEye" 
                                                Fill="Gray"
                                                Data="M12,9A3,3 0 0,0 9,12A3,3 0 0,0 12,15A3,3 0 0,0 15,12A3,3 0 0,0 12,9M12,17A5,5 0 0,1 7,12A5,5 0 0,1 12,7A5,5 0 0,1 17,12A5,5 0 0,1 12,17M12,4.5C7,4.5 2.73,7.61 1,12C2.73,16.39 7,19.5 12,19.5C17,19.5 21.27,16.39 23,12C21.27,7.61 17,4.5 12,4.5Z"/>
                                        </Viewbox>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="IconEye" Property="Fill" Value="#333"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                    </Grid>
                    
                </Border>

                <Button Content="ĐĂNG NHẬP" Height="60" Margin="0,0,0,20" FontWeight="Bold" FontSize="22" Cursor="Hand" Click="BtnLogin_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#C62828"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" 
                                            Background="{TemplateBinding Background}" 
                                            CornerRadius="15">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>

                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#B71C1C"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#800000"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <Grid>
                    <TextBlock Text="Bạn quên mật khẩu?" Foreground="Gray" HorizontalAlignment="Left" Cursor="Hand" FontSize="18"/>
                    <StackPanel HorizontalAlignment="Right" Margin="0,0,0,20">
                        <TextBlock Text="Bạn không có tài khoản?" Foreground="Gray" FontSize="18" HorizontalAlignment="Right" Margin="0,0,0,5"/>

                        <Button Content="Đăng ký ngay" HorizontalAlignment="Right" Cursor="Hand" Click="BtnDangKy_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <ContentPresenter/>
                                </ControlTemplate>
                            </Button.Template>

                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="FontSize" Value="18"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="Foreground" Value="#C62828"/>
                                    <Setter Property="Background" Value="Transparent"/>

                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Foreground" Value="#8E0000"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <TextBlock Text="{TemplateBinding Content}" TextDecorations="Underline"/>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Viewbox>
    </Grid>
</Page>