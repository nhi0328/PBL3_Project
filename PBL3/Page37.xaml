<Page x:Class="PBL3.Page37"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:local="clr-namespace:PBL3"
      mc:Ignorable="d"
      d:DesignHeight="792.8" d:DesignWidth="1536"
      Title="OTP" Background="White">

    <Grid>
        <Button Content="&lt; Quay lại" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="30" Background="Transparent" BorderThickness="0" FontSize="20" Cursor="Hand" Click="BtnBack_Click">
            <Button.Style>
                <Style TargetType="Button">
                    <Setter Property="Foreground" Value="Gray"/>

                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border Background="Transparent">
                                    <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                </Border>

                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Foreground" Value="#C62828"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Button.Style>
        </Button>

        <Viewbox Stretch="Uniform" VerticalAlignment="Center" HorizontalAlignment="Center">

            <StackPanel Width="600" Margin="0,80,0,80">
                <TextBlock Text="QUÊN MẬT KHẨU" FontSize="60" FontFamily="Calibri"
                           HorizontalAlignment="Center" Margin="0,0,0,40"/>

                <TextBlock Text="Nhập mã OTP" FontSize="36" FontFamily="Calibri" HorizontalAlignment="Center" Margin="0,0,0,30"/>

                <TextBlock FontSize="18" FontFamily="Calibri" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,0,0,30">
                    <Run Text="Công dân vui lòng nhập mã OTP đã được"/>
                    <LineBreak />
                    <Run Text="gửi về Email "/>
                    <Run x:Name="runEmail" Text="anh*****06@gmail.com." Foreground="#8BC34A"/>
                </TextBlock>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,15">
                    <!-- Input Boxes -->
                    <TextBox x:Name="txtOTP1" Width="55" Height="65" Margin="4" FontSize="30" TextAlignment="Center" VerticalContentAlignment="Center" MaxLength="1" BorderBrush="#CCC" BorderThickness="1">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>
                    <TextBox x:Name="txtOTP2" Width="55" Height="65" Margin="4" FontSize="30" TextAlignment="Center" VerticalContentAlignment="Center" MaxLength="1" BorderBrush="#CCC" BorderThickness="1">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>
                    <TextBox x:Name="txtOTP3" Width="55" Height="65" Margin="4" FontSize="30" TextAlignment="Center" VerticalContentAlignment="Center" MaxLength="1" BorderBrush="#CCC" BorderThickness="1">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>
                    <TextBox x:Name="txtOTP4" Width="55" Height="65" Margin="4" FontSize="30" TextAlignment="Center" VerticalContentAlignment="Center" MaxLength="1" BorderBrush="#CCC" BorderThickness="1">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>
                    <TextBox x:Name="txtOTP5" Width="55" Height="65" Margin="4" FontSize="30" TextAlignment="Center" VerticalContentAlignment="Center" MaxLength="1" BorderBrush="#CCC" BorderThickness="1">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>
                    <TextBox x:Name="txtOTP6" Width="55" Height="65" Margin="4" FontSize="30" TextAlignment="Center" VerticalContentAlignment="Center" MaxLength="1" BorderBrush="#CCC" BorderThickness="1">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>
                </StackPanel>

                <Grid Margin="120,0,120,30">
                    <Button x:Name="btnGuiLaiMa" Content="Gửi lại mã" HorizontalAlignment="Left" Background="White" Foreground="LightGray" BorderBrush="#999" BorderThickness="1" Padding="15,4" FontSize="16" FontFamily="Calibri" Cursor="Arrow" IsEnabled="False" Click="btnGuiLaiMa_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="16" FontFamily="Calibri" Foreground="#333">
                        <Run Text="Thời gian còn lại "/>
                        <Run x:Name="runTimer" Text="60s" FontWeight="Bold"/>
                        <Run Text="."/>
                    </TextBlock>
                </Grid>

                <Button Content="Xác nhận" Width="380" Background="#C62828" Foreground="White" Height="50" FontSize="22" FontFamily="Calibri" BorderThickness="0" Cursor="Hand" Margin="0,10,0,0" Click="btnXacNhan_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Viewbox>
    </Grid>
</Page>